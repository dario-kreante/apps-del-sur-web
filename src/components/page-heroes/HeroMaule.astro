---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Paisaje del Maule con viñedos, edificios de servicios y panel de gestión digital">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>

  <!-- Sky -->
  <rect x="0" y="0" width="800" height="90" rx="12" fill="#f0fdf4" opacity="0.4"/>

  <!-- Andes mountains -->
  <path d="M0,100 L80,60 L150,80 L220,45 L300,75 L380,50 L460,70 L540,40 L620,72 L700,55 L800,80 L800,110 L0,110 Z" fill="#d1fae5" opacity="0.4"/>

  <!-- Vineyard rows -->
  <g opacity="0.7">
    <rect x="20" y="120" width="160" height="4" rx="2" fill="#059669" opacity="0.3"/>
    <rect x="20" y="133" width="160" height="4" rx="2" fill="#10b981" opacity="0.35"/>
    <rect x="20" y="146" width="160" height="4" rx="2" fill="#059669" opacity="0.3"/>
    <rect x="20" y="159" width="160" height="4" rx="2" fill="#10b981" opacity="0.35"/>
    <rect x="20" y="172" width="160" height="4" rx="2" fill="#059669" opacity="0.3"/>
  </g>

  <!-- Grape clusters -->
  <g fill="#047857" opacity="0.35">
    <circle cx="55" cy="115" r="3"/><circle cx="60" cy="112" r="3"/><circle cx="65" cy="115" r="3"/>
    <circle cx="115" cy="115" r="3"/><circle cx="120" cy="112" r="3"/><circle cx="125" cy="115" r="3"/>
  </g>

  <!-- Hotel building -->
  <g transform="translate(200, 130)">
    <rect x="0" y="10" width="45" height="55" rx="3" fill="#047857" opacity="0.2"/>
    <rect x="5" y="18" width="10" height="8" rx="1" fill="#059669" opacity="0.3"/>
    <rect x="20" y="18" width="10" height="8" rx="1" fill="#059669" opacity="0.3"/>
    <rect x="5" y="32" width="10" height="8" rx="1" fill="#059669" opacity="0.3"/>
    <rect x="20" y="32" width="10" height="8" rx="1" fill="#059669" opacity="0.3"/>
    <rect x="5" y="46" width="10" height="8" rx="1" fill="#059669" opacity="0.3"/>
    <rect x="20" y="46" width="10" height="8" rx="1" fill="#059669" opacity="0.3"/>
    <rect x="15" y="55" width="12" height="10" rx="1" fill="#047857" opacity="0.3"/>
  </g>

  <!-- Health center -->
  <g transform="translate(260, 155)">
    <rect x="0" y="5" width="35" height="30" rx="3" fill="#047857" opacity="0.2"/>
    <rect x="14" y="10" width="7" height="3" rx="0.5" fill="#059669" opacity="0.5"/>
    <rect x="16" y="8" width="3" height="7" rx="0.5" fill="#059669" opacity="0.5"/>
    <rect x="5" y="20" width="8" height="6" rx="1" fill="#059669" opacity="0.3"/>
    <rect x="20" y="20" width="8" height="6" rx="1" fill="#059669" opacity="0.3"/>
  </g>

  <!-- Shop/commerce -->
  <g transform="translate(310, 165)">
    <rect x="0" y="5" width="30" height="22" rx="2" fill="#047857" opacity="0.2"/>
    <rect x="3" y="8" width="24" height="10" rx="1" fill="#059669" opacity="0.2"/>
    <rect x="10" y="20" width="10" height="7" rx="1" fill="#047857" opacity="0.3"/>
  </g>

  <!-- Truck (logistics) -->
  <g transform="translate(50, 195)">
    <rect x="0" y="3" width="30" height="14" rx="3" fill="#047857" opacity="0.35"/>
    <rect x="24" y="0" width="12" height="10" rx="2" fill="#047857" opacity="0.3"/>
    <circle cx="8" cy="19" r="5" fill="#047857" opacity="0.25" stroke="#047857" stroke-width="0.8" stroke-opacity="0.4"/>
    <circle cx="29" cy="17" r="4" fill="#047857" opacity="0.25" stroke="#047857" stroke-width="0.8" stroke-opacity="0.4"/>
  </g>

  <!-- Ground line -->
  <rect x="0" y="240" width="400" height="20" rx="0" fill="#d1fae5" opacity="0.3"/>

  <!-- Dashboard panel -->
  <rect x="420" y="30" width="340" height="200" rx="12" fill="#ffffff" stroke="#e5e7eb" stroke-width="1"/>
  <rect x="420" y="30" width="340" height="36" rx="12" fill="#047857"/>
  <rect x="420" y="54" width="340" height="12" fill="#047857"/>
  <text x="440" y="53" font-family="system-ui,sans-serif" font-size="11" font-weight="600" fill="#ffffff">Región del Maule — Multi-sector</text>
  <circle cx="738" cy="48" r="4" fill="#a7f3d0"/>

  <!-- Stat cards row -->
  <g transform="translate(436, 80)">
    <rect x="0" y="0" width="72" height="44" rx="6" fill="#f0fdf4" stroke="#d1fae5" stroke-width="0.5"/>
    <text x="10" y="18" font-family="system-ui,sans-serif" font-size="14" font-weight="700" fill="#047857">52K+</text>
    <text x="10" y="32" font-family="system-ui,sans-serif" font-size="7" fill="#6b7280">Pymes activas</text>
  </g>
  <g transform="translate(516, 80)">
    <rect x="0" y="0" width="72" height="44" rx="6" fill="#f0fdf4" stroke="#d1fae5" stroke-width="0.5"/>
    <text x="10" y="18" font-family="system-ui,sans-serif" font-size="14" font-weight="700" fill="#047857">8+</text>
    <text x="10" y="32" font-family="system-ui,sans-serif" font-size="7" fill="#6b7280">Rubros</text>
  </g>
  <g transform="translate(596, 80)">
    <rect x="0" y="0" width="72" height="44" rx="6" fill="#f0fdf4" stroke="#d1fae5" stroke-width="0.5"/>
    <text x="10" y="18" font-family="system-ui,sans-serif" font-size="14" font-weight="700" fill="#047857">98%</text>
    <text x="10" y="32" font-family="system-ui,sans-serif" font-size="7" fill="#6b7280">Cofinanciamiento</text>
  </g>
  <g transform="translate(676, 80)">
    <rect x="0" y="0" width="72" height="44" rx="6" fill="#f0fdf4" stroke="#d1fae5" stroke-width="0.5"/>
    <text x="10" y="18" font-family="system-ui,sans-serif" font-size="14" font-weight="700" fill="#047857">8-12</text>
    <text x="10" y="32" font-family="system-ui,sans-serif" font-size="7" fill="#6b7280">Semanas</text>
  </g>

  <!-- Sector list -->
  <g transform="translate(436, 138)">
    <rect x="0" y="0" width="152" height="18" rx="4" fill="#ecfdf5"/>
    <circle cx="10" cy="9" r="3" fill="#10b981"/>
    <text x="20" y="12" font-family="system-ui,sans-serif" font-size="8" fill="#374151">Vitivinícola</text>
  </g>
  <g transform="translate(596, 138)">
    <rect x="0" y="0" width="152" height="18" rx="4" fill="#ecfdf5"/>
    <circle cx="10" cy="9" r="3" fill="#10b981"/>
    <text x="20" y="12" font-family="system-ui,sans-serif" font-size="8" fill="#374151">Hotelería</text>
  </g>
  <g transform="translate(436, 162)">
    <rect x="0" y="0" width="152" height="18" rx="4" fill="#ecfdf5"/>
    <circle cx="10" cy="9" r="3" fill="#10b981"/>
    <text x="20" y="12" font-family="system-ui,sans-serif" font-size="8" fill="#374151">Salud</text>
  </g>
  <g transform="translate(596, 162)">
    <rect x="0" y="0" width="152" height="18" rx="4" fill="#ecfdf5"/>
    <circle cx="10" cy="9" r="3" fill="#10b981"/>
    <text x="20" y="12" font-family="system-ui,sans-serif" font-size="8" fill="#374151">Logística</text>
  </g>
  <g transform="translate(436, 186)">
    <rect x="0" y="0" width="152" height="18" rx="4" fill="#ecfdf5"/>
    <circle cx="10" cy="9" r="3" fill="#10b981"/>
    <text x="20" y="12" font-family="system-ui,sans-serif" font-size="8" fill="#374151">Estética</text>
  </g>
  <g transform="translate(596, 186)">
    <rect x="0" y="0" width="152" height="18" rx="4" fill="#ecfdf5"/>
    <circle cx="10" cy="9" r="3" fill="#10b981"/>
    <text x="20" y="12" font-family="system-ui,sans-serif" font-size="8" fill="#374151">Comercio</text>
  </g>

  <!-- CTA button -->
  <rect x="436" y="212" width="120" height="10" rx="5" fill="#047857" opacity="0.6"/>
  <text x="450" y="220" font-family="system-ui,sans-serif" font-size="6" font-weight="600" fill="#ffffff">Diagnóstico gratis</text>
</svg>
