---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 280" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Agente IA de compliance regulatorio chileno con checklist SAG, alertas de vencimiento y carpeta de fiscalización">
  <defs>
    <linearGradient id="bg-gradient-comp" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#f0fdf4"/>
      <stop offset="100%" stop-color="#dcfce7"/>
    </linearGradient>
  </defs>
  <rect width="800" height="280" fill="url(#bg-gradient-comp)" rx="12"/>

  <!-- Left: Compliance dashboard -->
  <rect x="40" y="32" width="340" height="216" rx="12" fill="#ffffff" stroke="#d1fae5" stroke-width="1.5"/>
  <rect x="40" y="32" width="340" height="38" rx="12" fill="#047857"/>
  <rect x="40" y="58" width="340" height="12" fill="#047857"/>
  <text x="60" y="56" font-family="system-ui,sans-serif" font-size="12" font-weight="600" fill="#ffffff">🛡️ Compliance Viña Tipo</text>
  <rect x="305" y="44" width="60" height="16" rx="8" fill="#dcfce7"/>
  <text x="335" y="55" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#065f46" text-anchor="middle">✓ Al día</text>

  <!-- Tabs -->
  <g transform="translate(55, 80)">
    <text x="0" y="10" font-family="system-ui,sans-serif" font-size="9" fill="#9ca3af" font-weight="500">Próximos vencimientos</text>
  </g>

  <!-- Vencimientos -->
  <rect x="55" y="98" width="310" height="32" rx="6" fill="#ecfdf5" stroke="#a7f3d0"/>
  <circle cx="72" cy="114" r="6" fill="#10b981"/>
  <text x="68" y="118" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">✓</text>
  <text x="86" y="111" font-family="system-ui,sans-serif" font-size="10" fill="#065f46" font-weight="600">Sustentavid · Op. Juan Pérez</text>
  <text x="86" y="124" font-family="system-ui,sans-serif" font-size="8" fill="#6b7280">Vence en 30 días · 18 jun</text>
  <text x="320" y="119" font-family="system-ui,sans-serif" font-size="8" fill="#059669" font-weight="700">⚠</text>

  <rect x="55" y="138" width="310" height="32" rx="6" fill="#fefce8" stroke="#fde68a"/>
  <circle cx="72" cy="154" r="6" fill="#eab308"/>
  <text x="68" y="158" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">!</text>
  <text x="86" y="151" font-family="system-ui,sans-serif" font-size="10" fill="#854d0e" font-weight="600">Inventario plaguicidas SAG</text>
  <text x="86" y="164" font-family="system-ui,sans-serif" font-size="8" fill="#6b7280">Vence en 5 días · 22 may</text>
  <text x="328" y="159" font-family="system-ui,sans-serif" font-size="8" fill="#d97706" font-weight="700">URGENTE</text>

  <rect x="55" y="178" width="310" height="32" rx="6" fill="#ecfdf5" stroke="#a7f3d0"/>
  <circle cx="72" cy="194" r="6" fill="#10b981"/>
  <text x="68" y="198" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">✓</text>
  <text x="86" y="191" font-family="system-ui,sans-serif" font-size="10" fill="#065f46" font-weight="600">GlobalG.A.P. recertificación</text>
  <text x="86" y="204" font-family="system-ui,sans-serif" font-size="8" fill="#6b7280">En 92 días · 16 ago</text>

  <!-- Compliance score -->
  <rect x="55" y="218" width="310" height="20" rx="4" fill="#f0fdf4"/>
  <rect x="55" y="218" width="270" height="20" rx="4" fill="#10b981"/>
  <text x="65" y="232" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">87% compliance score</text>
  <text x="335" y="232" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#065f46">87/100</text>

  <!-- Right: Phone with compliance chat -->
  <rect x="445" y="20" width="220" height="245" rx="22" fill="#1f2937" stroke="#0f172a" stroke-width="3"/>
  <rect x="460" y="36" width="190" height="213" rx="3" fill="#0b141a"/>

  <rect x="460" y="36" width="190" height="32" fill="#202c33"/>
  <circle cx="479" cy="52" r="9" fill="#059669"/>
  <text x="475" y="56" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">🛡</text>
  <text x="495" y="51" font-family="system-ui,sans-serif" font-size="9" font-weight="600" fill="#ffffff">Compliance IA</text>
  <text x="495" y="61" font-family="system-ui,sans-serif" font-size="7" fill="#10b981">● SAG · Sustentavid</text>

  <rect x="468" y="80" width="148" height="42" rx="6" fill="#202c33"/>
  <text x="474" y="92" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">Aplicamos glifosato 3 L/ha</text>
  <text x="474" y="102" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">en cuartel 12 esta mañana</text>
  <text x="474" y="113" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">¿cómo lo registro?</text>

  <rect x="490" y="130" width="148" height="58" rx="6" fill="#005c4b"/>
  <text x="496" y="143" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff" font-weight="600">✅ Registrado.</text>
  <text x="496" y="155" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">⚠ Carencia 14 días.</text>
  <text x="496" y="166" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">No cosechar antes</text>
  <text x="496" y="176" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">del 31 mayo.</text>

  <rect x="468" y="196" width="148" height="42" rx="6" fill="#005c4b" opacity="0.85"/>
  <text x="474" y="208" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff" font-weight="600">📋 Si SAG llega hoy:</text>
  <text x="474" y="220" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">carpeta lista en 2 min.</text>
  <text x="474" y="231" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">¿La genero?</text>

  <!-- Connector -->
  <path d="M 380 140 Q 410 140 445 140" stroke="#10b981" stroke-width="2" stroke-dasharray="3 3" fill="none" opacity="0.5"/>

  <!-- SAG badge -->
  <rect x="290" y="6" width="84" height="20" rx="10" fill="#047857"/>
  <text x="332" y="20" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff" text-anchor="middle">SAG · SII · ISP</text>
</svg>
