---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 280" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Agente IA atendiendo múltiples conversaciones de WhatsApp en paralelo">
  <defs>
    <linearGradient id="bg-gradient-wa" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#f0fdf4"/>
      <stop offset="100%" stop-color="#dcfce7"/>
    </linearGradient>
  </defs>
  <rect width="800" height="280" fill="url(#bg-gradient-wa)" rx="12"/>

  <!-- Central agent hub -->
  <circle cx="400" cy="140" r="58" fill="#047857"/>
  <circle cx="400" cy="140" r="58" fill="none" stroke="#10b981" stroke-width="2" opacity="0.5"/>
  <circle cx="400" cy="140" r="70" fill="none" stroke="#10b981" stroke-width="1" opacity="0.3"/>
  <circle cx="400" cy="140" r="85" fill="none" stroke="#10b981" stroke-width="1" opacity="0.15"/>

  <!-- WhatsApp icon in center -->
  <g transform="translate(370, 110)">
    <path d="M30.5 4.5C16.7 4.5 5.5 15.7 5.5 29.5c0 4.4 1.2 8.7 3.4 12.5L5 55l13.4-3.5c3.7 2 7.9 3 12.1 3 13.8 0 25-11.2 25-25s-11.2-25-25-25z" fill="#ffffff"/>
    <path d="M44.3 36.4c-.6-.3-3.5-1.7-4-1.9-.5-.2-.9-.3-1.3.3-.4.6-1.5 1.9-1.8 2.3-.3.4-.7.4-1.3.1-.6-.3-2.5-.9-4.8-2.9-1.8-1.6-3-3.5-3.3-4.1-.3-.6 0-.9.3-1.2.3-.3.6-.7.9-1 .3-.3.4-.5.6-.9.2-.4.1-.7-.1-1-.1-.3-1.3-3.1-1.8-4.2-.5-1.1-.9-1-1.3-1h-1.1c-.4 0-1 .1-1.5.7-.5.6-2 1.9-2 4.7s2.1 5.5 2.3 5.8c.3.4 4 6.1 9.8 8.6 5.7 2.5 5.7 1.7 6.7 1.6 1.1-.1 3.5-1.4 4-2.8.5-1.4.5-2.5.3-2.8-.1-.3-.5-.4-1.1-.7z" fill="#047857"/>
  </g>

  <!-- "AI" badge -->
  <rect x="412" y="165" width="36" height="14" rx="7" fill="#ffffff"/>
  <text x="430" y="175" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#047857" text-anchor="middle">IA</text>

  <!-- Chat bubbles around -->
  <!-- Top-left -->
  <g transform="translate(60, 30)">
    <rect width="150" height="60" rx="10" fill="#ffffff" stroke="#d1fae5"/>
    <circle cx="20" cy="20" r="10" fill="#dbeafe"/>
    <text x="20" y="24" font-family="system-ui,sans-serif" font-size="9" fill="#1e40af" text-anchor="middle" font-weight="600">M</text>
    <text x="40" y="20" font-family="system-ui,sans-serif" font-size="9" font-weight="600" fill="#111827">María — Pedido</text>
    <text x="40" y="33" font-family="system-ui,sans-serif" font-size="8" fill="#6b7280">¿Dónde está mi pedido?</text>
    <rect x="40" y="42" width="100" height="12" rx="3" fill="#ecfdf5"/>
    <text x="44" y="51" font-family="system-ui,sans-serif" font-size="7" fill="#065f46">En camino · hoy 17h</text>
  </g>

  <!-- Top-right -->
  <g transform="translate(590, 25)">
    <rect width="155" height="60" rx="10" fill="#ffffff" stroke="#d1fae5"/>
    <circle cx="20" cy="20" r="10" fill="#fef3c7"/>
    <text x="20" y="24" font-family="system-ui,sans-serif" font-size="9" fill="#92400e" text-anchor="middle" font-weight="600">J</text>
    <text x="40" y="20" font-family="system-ui,sans-serif" font-size="9" font-weight="600" fill="#111827">Jorge — Talla M</text>
    <text x="40" y="33" font-family="system-ui,sans-serif" font-size="8" fill="#6b7280">Polera mostaza M</text>
    <rect x="40" y="42" width="105" height="12" rx="3" fill="#ecfdf5"/>
    <text x="44" y="51" font-family="system-ui,sans-serif" font-size="7" fill="#065f46">Link de pago enviado</text>
  </g>

  <!-- Bottom-left -->
  <g transform="translate(60, 200)">
    <rect width="155" height="55" rx="10" fill="#ffffff" stroke="#d1fae5"/>
    <circle cx="20" cy="20" r="10" fill="#fce7f3"/>
    <text x="20" y="24" font-family="system-ui,sans-serif" font-size="9" fill="#9d174d" text-anchor="middle" font-weight="600">C</text>
    <text x="40" y="20" font-family="system-ui,sans-serif" font-size="9" font-weight="600" fill="#111827">Camila — Devolución</text>
    <text x="40" y="33" font-family="system-ui,sans-serif" font-size="8" fill="#6b7280">Cambio de talla</text>
    <rect x="40" y="42" width="100" height="10" rx="3" fill="#ecfdf5"/>
    <text x="44" y="50" font-family="system-ui,sans-serif" font-size="7" fill="#065f46">Etiqueta generada ✓</text>
  </g>

  <!-- Bottom-right -->
  <g transform="translate(590, 200)">
    <rect width="155" height="55" rx="10" fill="#ffffff" stroke="#d1fae5"/>
    <circle cx="20" cy="20" r="10" fill="#dcfce7"/>
    <text x="20" y="24" font-family="system-ui,sans-serif" font-size="9" fill="#166534" text-anchor="middle" font-weight="600">A</text>
    <text x="40" y="20" font-family="system-ui,sans-serif" font-size="9" font-weight="600" fill="#111827">Andrea — Stock</text>
    <text x="40" y="33" font-family="system-ui,sans-serif" font-size="8" fill="#6b7280">Hay en negro?</text>
    <rect x="40" y="42" width="105" height="10" rx="3" fill="#ecfdf5"/>
    <text x="44" y="50" font-family="system-ui,sans-serif" font-size="7" fill="#065f46">Sí, 12 unidades</text>
  </g>

  <!-- Connecting lines -->
  <line x1="210" y1="60" x2="345" y2="125" stroke="#10b981" stroke-width="1.5" opacity="0.4" stroke-dasharray="3 3"/>
  <line x1="590" y1="55" x2="455" y2="125" stroke="#10b981" stroke-width="1.5" opacity="0.4" stroke-dasharray="3 3"/>
  <line x1="215" y1="222" x2="345" y2="158" stroke="#10b981" stroke-width="1.5" opacity="0.4" stroke-dasharray="3 3"/>
  <line x1="590" y1="220" x2="455" y2="158" stroke="#10b981" stroke-width="1.5" opacity="0.4" stroke-dasharray="3 3"/>

  <!-- Stats badge -->
  <rect x="320" y="240" width="170" height="30" rx="15" fill="#ffffff" stroke="#d1fae5"/>
  <text x="405" y="260" font-family="system-ui,sans-serif" font-size="11" fill="#047857" font-weight="700" text-anchor="middle">⚡ 1.247 mensajes hoy · 98% resueltos</text>
</svg>
