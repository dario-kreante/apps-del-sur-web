---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 280" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Agente IA orientando a familia sobre cuota mortuoria de AFP e IPS en Chile">
  <defs>
    <linearGradient id="bg-gradient-cm" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#f8fafc"/>
      <stop offset="100%" stop-color="#e2e8f0"/>
    </linearGradient>
  </defs>
  <rect width="800" height="280" fill="url(#bg-gradient-cm)" rx="12"/>

  <!-- Left: Cuota mortuoria calculator card -->
  <rect x="40" y="32" width="340" height="216" rx="12" fill="#ffffff" stroke="#cbd5e1" stroke-width="1.5"/>
  <rect x="40" y="32" width="340" height="38" rx="12" fill="#475569"/>
  <rect x="40" y="58" width="340" height="12" fill="#475569"/>
  <text x="60" y="56" font-family="system-ui,sans-serif" font-size="12" font-weight="600" fill="#ffffff">🤍 Cuota Mortuoria · Beneficio</text>
  <rect x="305" y="44" width="60" height="16" rx="8" fill="#e0e7ff"/>
  <text x="335" y="55" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#3730a3" text-anchor="middle">Vigente</text>

  <!-- Monto card -->
  <rect x="55" y="84" width="310" height="64" rx="8" fill="#f0f9ff" stroke="#bae6fd"/>
  <text x="65" y="100" font-family="system-ui,sans-serif" font-size="9" fill="#0369a1" font-weight="500">Monto aproximado</text>
  <text x="65" y="128" font-family="system-ui,sans-serif" font-size="24" font-weight="800" fill="#0c4a6e">~$580.000</text>
  <text x="220" y="128" font-family="system-ui,sans-serif" font-size="11" fill="#0369a1" font-weight="600">CLP</text>
  <text x="65" y="142" font-family="system-ui,sans-serif" font-size="8" fill="#64748b">≈ 15 UF · valor referencial 2026</text>

  <!-- Steps -->
  <text x="55" y="166" font-family="system-ui,sans-serif" font-size="9" fill="#9ca3af" font-weight="500">Documentos requeridos</text>

  <rect x="55" y="172" width="310" height="22" rx="4" fill="#f8fafc" stroke="#e2e8f0"/>
  <circle cx="68" cy="183" r="5" fill="#10b981"/>
  <text x="64" y="187" font-family="system-ui,sans-serif" font-size="7" font-weight="700" fill="#ffffff">✓</text>
  <text x="80" y="187" font-family="system-ui,sans-serif" font-size="9" fill="#475569">Certificado de defunción</text>

  <rect x="55" y="198" width="310" height="22" rx="4" fill="#f8fafc" stroke="#e2e8f0"/>
  <circle cx="68" cy="209" r="5" fill="#10b981"/>
  <text x="64" y="213" font-family="system-ui,sans-serif" font-size="7" font-weight="700" fill="#ffffff">✓</text>
  <text x="80" y="213" font-family="system-ui,sans-serif" font-size="9" fill="#475569">Factura de la funeraria</text>

  <rect x="55" y="224" width="310" height="22" rx="4" fill="#fefce8" stroke="#fde68a"/>
  <circle cx="68" cy="235" r="5" fill="#eab308"/>
  <text x="64" y="239" font-family="system-ui,sans-serif" font-size="7" font-weight="700" fill="#ffffff">!</text>
  <text x="80" y="239" font-family="system-ui,sans-serif" font-size="9" fill="#854d0e">Cédula vigente · pendiente</text>

  <!-- Right: Phone with funerary chat -->
  <rect x="445" y="20" width="220" height="245" rx="22" fill="#1f2937" stroke="#0f172a" stroke-width="3"/>
  <rect x="460" y="36" width="190" height="213" rx="3" fill="#0b141a"/>

  <rect x="460" y="36" width="190" height="32" fill="#202c33"/>
  <circle cx="479" cy="52" r="9" fill="#64748b"/>
  <text x="475" y="56" font-family="system-ui,sans-serif" font-size="10" font-weight="700" fill="#ffffff">🤍</text>
  <text x="495" y="51" font-family="system-ui,sans-serif" font-size="9" font-weight="600" fill="#ffffff">Funeraria · IA</text>
  <text x="495" y="61" font-family="system-ui,sans-serif" font-size="7" fill="#94a3b8">● 15:23 · respondiendo</text>

  <!-- Messages -->
  <rect x="468" y="80" width="160" height="42" rx="6" fill="#202c33"/>
  <text x="474" y="92" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">Falleció mi padre el</text>
  <text x="474" y="102" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">martes. Me dijeron que</text>
  <text x="474" y="113" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">la AFP paga algo, ¿es real?</text>

  <rect x="488" y="130" width="150" height="56" rx="6" fill="#005c4b"/>
  <text x="494" y="142" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff" font-weight="600">Lamento su pérdida 🤍</text>
  <text x="494" y="153" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">Sí: se llama **cuota</text>
  <text x="494" y="163" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">mortuoria**, ~15 UF</text>
  <text x="494" y="174" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">(~$580.000)</text>

  <rect x="468" y="194" width="115" height="20" rx="6" fill="#202c33"/>
  <text x="474" y="208" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">¿Cómo lo solicito?</text>

  <rect x="488" y="222" width="150" height="20" rx="6" fill="#005c4b"/>
  <text x="494" y="236" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff" font-weight="600">📋 Le guío paso a paso →</text>

  <!-- Connector -->
  <path d="M 380 140 Q 410 140 445 140" stroke="#64748b" stroke-width="2" stroke-dasharray="3 3" fill="none" opacity="0.5"/>

  <!-- AFP/IPS badge -->
  <rect x="295" y="6" width="84" height="20" rx="10" fill="#475569"/>
  <text x="337" y="20" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff" text-anchor="middle">AFP · IPS · CCAF</text>
</svg>
