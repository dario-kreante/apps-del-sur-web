---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 280" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Agente IA detectando clientes en riesgo y rescatándolos antes del churn">
  <defs>
    <linearGradient id="bg-gradient-ret" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#f0fdf4"/>
      <stop offset="100%" stop-color="#dcfce7"/>
    </linearGradient>
  </defs>
  <rect width="800" height="280" fill="url(#bg-gradient-ret)" rx="12"/>

  <!-- Left: Churn chart panel -->
  <rect x="40" y="35" width="340" height="210" rx="12" fill="#ffffff" stroke="#d1fae5" stroke-width="1.5"/>
  <rect x="40" y="35" width="340" height="34" rx="12" fill="#047857"/>
  <rect x="40" y="59" width="340" height="10" fill="#047857"/>
  <text x="60" y="56" font-family="system-ui,sans-serif" font-size="11" font-weight="600" fill="#ffffff">📉 Clientes en riesgo · 168</text>
  <rect x="320" y="46" width="50" height="16" rx="8" fill="#fbbf24"/>
  <text x="345" y="57" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#78350f" text-anchor="middle">Alto</text>

  <!-- Chart -->
  <g transform="translate(55, 85)">
    <!-- Bars: rescatados vs perdidos -->
    <text x="0" y="10" font-family="system-ui,sans-serif" font-size="9" fill="#374151" font-weight="500">Resultado mes (de 168)</text>

    <g transform="translate(0, 20)">
      <rect x="0" y="0" width="180" height="22" rx="4" fill="#dcfce7"/>
      <rect x="0" y="0" width="84" height="22" rx="4" fill="#059669"/>
      <text x="8" y="15" font-family="system-ui,sans-serif" font-size="9" fill="#ffffff" font-weight="700">78 rescatados</text>
      <text x="190" y="15" font-family="system-ui,sans-serif" font-size="9" fill="#065f46" font-weight="600">47%</text>
    </g>

    <g transform="translate(0, 52)">
      <rect x="0" y="0" width="180" height="22" rx="4" fill="#fee2e2"/>
      <rect x="0" y="0" width="96" height="22" rx="4" fill="#dc2626"/>
      <text x="8" y="15" font-family="system-ui,sans-serif" font-size="9" fill="#ffffff" font-weight="700">90 perdidos</text>
      <text x="190" y="15" font-family="system-ui,sans-serif" font-size="9" fill="#7f1d1d" font-weight="600">53%</text>
    </g>

    <!-- Money saved -->
    <rect x="0" y="90" width="295" height="50" rx="8" fill="#ecfdf5" stroke="#a7f3d0"/>
    <text x="12" y="108" font-family="system-ui,sans-serif" font-size="8" fill="#065f46" font-weight="500">Ingreso recuperado este mes</text>
    <text x="12" y="130" font-family="system-ui,sans-serif" font-size="22" fill="#047857" font-weight="800">$2.340.000</text>
    <text x="180" y="130" font-family="system-ui,sans-serif" font-size="9" fill="#059669" font-weight="600">↑ vs $0 antes</text>
  </g>

  <!-- Right: Phone with retention chat -->
  <rect x="445" y="22" width="220" height="245" rx="22" fill="#1f2937" stroke="#0f172a" stroke-width="3"/>
  <rect x="460" y="38" width="190" height="213" rx="3" fill="#0b141a"/>

  <!-- Header -->
  <rect x="460" y="38" width="190" height="32" fill="#202c33"/>
  <circle cx="479" cy="54" r="9" fill="#059669"/>
  <text x="476" y="58" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">G</text>
  <text x="495" y="53" font-family="system-ui,sans-serif" font-size="9" font-weight="600" fill="#ffffff">GymPower · IA</text>
  <text x="495" y="63" font-family="system-ui,sans-serif" font-size="7" fill="#10b981">● escribiendo...</text>

  <!-- Messages -->
  <rect x="500" y="82" width="138" height="38" rx="6" fill="#005c4b"/>
  <text x="506" y="94" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">¡Hola Pedro! 💪</text>
  <text x="506" y="103" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">No te vemos hace 3</text>
  <text x="506" y="112" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">semanas. ¿Todo bien?</text>

  <rect x="468" y="128" width="118" height="20" rx="6" fill="#202c33"/>
  <text x="474" y="142" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">Pensando en cancelar...</text>

  <rect x="490" y="156" width="148" height="65" rx="6" fill="#005c4b"/>
  <text x="496" y="168" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff" font-weight="600">Te ofrezco 2 opciones:</text>
  <text x="496" y="180" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">🌅 Plan Madrugador</text>
  <text x="496" y="190" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">  $19.990 (-$10K)</text>
  <text x="496" y="202" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">⏸ Pausar 2 meses</text>
  <text x="496" y="212" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">  sin costo</text>

  <rect x="468" y="227" width="105" height="20" rx="6" fill="#202c33"/>
  <text x="474" y="241" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">Madrugador, dale 🎉</text>

  <!-- "Rescatado" badge -->
  <rect x="565" y="227" width="73" height="20" rx="10" fill="#10b981"/>
  <text x="601" y="241" font-family="system-ui,sans-serif" font-size="8" font-weight="700" fill="#ffffff" text-anchor="middle">✓ Rescatado</text>

  <!-- Connector -->
  <path d="M 380 140 Q 410 140 445 140" stroke="#10b981" stroke-width="2" stroke-dasharray="3 3" fill="none" opacity="0.5"/>
</svg>
