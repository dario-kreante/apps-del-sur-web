---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Cuaderno de campo digital con registro fitosanitario en smartphone">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>

  <!-- Paper notebook (crossed out) -->
  <g transform="translate(80, 40)">
    <rect x="0" y="0" width="140" height="180" rx="4" fill="#ffffff" stroke="#d1d5db" stroke-width="1.5"/>
    <!-- Spiral binding -->
    <circle cx="15" cy="20" r="4" fill="none" stroke="#9ca3af" stroke-width="1.5"/>
    <circle cx="15" cy="45" r="4" fill="none" stroke="#9ca3af" stroke-width="1.5"/>
    <circle cx="15" cy="70" r="4" fill="none" stroke="#9ca3af" stroke-width="1.5"/>
    <circle cx="15" cy="95" r="4" fill="none" stroke="#9ca3af" stroke-width="1.5"/>
    <circle cx="15" cy="120" r="4" fill="none" stroke="#9ca3af" stroke-width="1.5"/>
    <circle cx="15" cy="145" r="4" fill="none" stroke="#9ca3af" stroke-width="1.5"/>
    <!-- Lines -->
    <line x1="30" y1="25" x2="125" y2="25" stroke="#e5e7eb" stroke-width="0.5"/>
    <line x1="30" y1="40" x2="125" y2="40" stroke="#e5e7eb" stroke-width="0.5"/>
    <line x1="30" y1="55" x2="125" y2="55" stroke="#e5e7eb" stroke-width="0.5"/>
    <line x1="30" y1="70" x2="125" y2="70" stroke="#e5e7eb" stroke-width="0.5"/>
    <line x1="30" y1="85" x2="125" y2="85" stroke="#e5e7eb" stroke-width="0.5"/>
    <!-- Scribbled text -->
    <rect x="33" y="28" width="60" height="6" rx="1" fill="#d1d5db"/>
    <rect x="33" y="43" width="80" height="6" rx="1" fill="#d1d5db"/>
    <rect x="33" y="58" width="50" height="6" rx="1" fill="#d1d5db"/>
    <rect x="33" y="73" width="70" height="6" rx="1" fill="#d1d5db"/>
    <!-- X mark (crossed out) -->
    <line x1="20" y1="10" x2="130" y2="170" stroke="#ef4444" stroke-width="3" opacity="0.4"/>
    <line x1="130" y1="10" x2="20" y2="170" stroke="#ef4444" stroke-width="3" opacity="0.4"/>
  </g>

  <!-- Arrow -->
  <g transform="translate(260, 120)">
    <line x1="0" y1="0" x2="50" y2="0" stroke="#047857" stroke-width="2.5"/>
    <polygon points="50,-6 62,0 50,6" fill="#047857"/>
  </g>

  <!-- Phone frame (digital version) -->
  <rect x="350" y="20" width="180" height="220" rx="18" fill="#1f2937"/>
  <rect x="358" y="38" width="164" height="184" rx="4" fill="#ffffff"/>

  <!-- Status bar -->
  <rect x="358" y="38" width="164" height="18" rx="4" fill="#d1fae5"/>
  <circle cx="374" cy="47" r="3" fill="#059669"/>
  <rect x="382" y="44" width="20" height="6" rx="2" fill="#059669"/>
  <rect x="496" y="44" width="18" height="6" rx="2" fill="#10b981"/>

  <!-- Title bar -->
  <rect x="358" y="56" width="164" height="22" fill="#047857"/>
  <text x="440" y="71" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">Cuaderno de Campo</text>

  <!-- Record entry 1 - completed -->
  <rect x="368" y="86" width="144" height="38" rx="4" fill="#f0fdf4" stroke="#d1fae5" stroke-width="0.5"/>
  <rect x="375" y="92" width="12" height="12" rx="3" fill="#059669"/>
  <polyline points="378,98 381,102 386,94" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  <text x="393" y="100" font-family="system-ui,sans-serif" font-size="7" font-weight="600" fill="#047857">Aplicación fungicida</text>
  <text x="393" y="112" font-family="system-ui,sans-serif" font-size="6" fill="#6b7280">C3B · Hoy 08:30 · GPS ✓</text>
  <rect x="475" y="104" width="30" height="12" rx="6" fill="#059669" opacity="0.15"/>
  <text x="480" y="113" font-family="system-ui,sans-serif" font-size="6" fill="#059669" font-weight="600">Foto ✓</text>

  <!-- Record entry 2 - completed -->
  <rect x="368" y="130" width="144" height="38" rx="4" fill="#f0fdf4" stroke="#d1fae5" stroke-width="0.5"/>
  <rect x="375" y="136" width="12" height="12" rx="3" fill="#059669"/>
  <polyline points="378,142 381,146 386,138" fill="none" stroke="#ffffff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  <text x="393" y="144" font-family="system-ui,sans-serif" font-size="7" font-weight="600" fill="#047857">Monitoreo plagas</text>
  <text x="393" y="156" font-family="system-ui,sans-serif" font-size="6" fill="#6b7280">C1A · Hoy 10:15 · GPS ✓</text>

  <!-- Record entry 3 - pending -->
  <rect x="368" y="174" width="144" height="38" rx="4" fill="#ffffff" stroke="#e5e7eb" stroke-width="0.5"/>
  <rect x="375" y="180" width="12" height="12" rx="3" fill="#d1fae5" stroke="#10b981" stroke-width="1"/>
  <text x="393" y="188" font-family="system-ui,sans-serif" font-size="7" font-weight="600" fill="#9ca3af">Riego programado</text>
  <text x="393" y="200" font-family="system-ui,sans-serif" font-size="6" fill="#d1d5db">C5 · Pendiente</text>

  <!-- Notch -->
  <rect x="410" y="20" width="60" height="12" rx="6" fill="#1f2937"/>

  <!-- Benefits callouts on the right -->
  <g transform="translate(570, 50)">
    <rect x="0" y="0" width="180" height="36" rx="8" fill="#ffffff" stroke="#d1fae5" stroke-width="1"/>
    <circle cx="18" cy="18" r="10" fill="#d1fae5"/>
    <text x="18" y="22" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#047857">📍</text>
    <text x="36" y="14" font-family="system-ui,sans-serif" font-size="8" font-weight="600" fill="#374151">Geolocalización GPS</text>
    <text x="36" y="26" font-family="system-ui,sans-serif" font-size="7" fill="#6b7280">Automática en cada registro</text>
  </g>

  <g transform="translate(570, 100)">
    <rect x="0" y="0" width="180" height="36" rx="8" fill="#ffffff" stroke="#d1fae5" stroke-width="1"/>
    <circle cx="18" cy="18" r="10" fill="#d1fae5"/>
    <text x="18" y="22" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#047857">📶</text>
    <text x="36" y="14" font-family="system-ui,sans-serif" font-size="8" font-weight="600" fill="#374151">Funciona offline</text>
    <text x="36" y="26" font-family="system-ui,sans-serif" font-size="7" fill="#6b7280">Sincroniza al recuperar señal</text>
  </g>

  <g transform="translate(570, 150)">
    <rect x="0" y="0" width="180" height="36" rx="8" fill="#ffffff" stroke="#d1fae5" stroke-width="1"/>
    <circle cx="18" cy="18" r="10" fill="#d1fae5"/>
    <text x="18" y="22" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#047857">✅</text>
    <text x="36" y="14" font-family="system-ui,sans-serif" font-size="8" font-weight="600" fill="#374151">Sustentavid y GlobalG.A.P.</text>
    <text x="36" y="26" font-family="system-ui,sans-serif" font-size="7" fill="#6b7280">Reportes automáticos</text>
  </g>

  <g transform="translate(570, 200)">
    <rect x="0" y="0" width="180" height="36" rx="8" fill="#ffffff" stroke="#d1fae5" stroke-width="1"/>
    <circle cx="18" cy="18" r="10" fill="#d1fae5"/>
    <text x="18" y="22" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#047857">📷</text>
    <text x="36" y="14" font-family="system-ui,sans-serif" font-size="8" font-weight="600" fill="#374151">Fotos y evidencia</text>
    <text x="36" y="26" font-family="system-ui,sans-serif" font-size="7" fill="#6b7280">Adjuntas al registro</text>
  </g>
</svg>
