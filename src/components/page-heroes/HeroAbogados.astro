---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 280" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Agente IA legal para estudios jurídicos chilenos atendiendo clientes y vigilando causas en Oficina Judicial Virtual">
  <defs>
    <linearGradient id="bg-gradient-abg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#f0fdf4"/>
      <stop offset="100%" stop-color="#dcfce7"/>
    </linearGradient>
  </defs>
  <rect width="800" height="280" fill="url(#bg-gradient-abg)" rx="12"/>

  <!-- Left: Legal dashboard with cases -->
  <rect x="40" y="32" width="340" height="216" rx="12" fill="#ffffff" stroke="#d1fae5" stroke-width="1.5"/>
  <rect x="40" y="32" width="340" height="38" rx="12" fill="#047857"/>
  <rect x="40" y="58" width="340" height="12" fill="#047857"/>
  <text x="60" y="56" font-family="system-ui,sans-serif" font-size="12" font-weight="600" fill="#ffffff">⚖️ Causas activas · PJUD</text>
  <rect x="305" y="44" width="60" height="16" rx="8" fill="#dcfce7"/>
  <text x="335" y="55" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#065f46" text-anchor="middle">14 activas</text>

  <text x="55" y="90" font-family="system-ui,sans-serif" font-size="9" fill="#9ca3af" font-weight="500">Próximos vencimientos PJUD</text>

  <!-- Causa 1 -->
  <rect x="55" y="98" width="310" height="32" rx="6" fill="#fef2f2" stroke="#fecaca"/>
  <circle cx="72" cy="114" r="6" fill="#dc2626"/>
  <text x="68" y="118" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">!</text>
  <text x="86" y="111" font-family="system-ui,sans-serif" font-size="10" fill="#7f1d1d" font-weight="600">González c/ AFP — Contestar</text>
  <text x="86" y="124" font-family="system-ui,sans-serif" font-size="8" fill="#6b7280">Plazo: mañana 12:00 · 1° Lab Stgo</text>
  <text x="326" y="119" font-family="system-ui,sans-serif" font-size="8" fill="#dc2626" font-weight="700">24h</text>

  <!-- Causa 2 -->
  <rect x="55" y="138" width="310" height="32" rx="6" fill="#fefce8" stroke="#fde68a"/>
  <circle cx="72" cy="154" r="6" fill="#eab308"/>
  <text x="68" y="158" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">!</text>
  <text x="86" y="151" font-family="system-ui,sans-serif" font-size="10" fill="#854d0e" font-weight="600">Soto c/ Seguros — Audiencia</text>
  <text x="86" y="164" font-family="system-ui,sans-serif" font-size="8" fill="#6b7280">Jue 22 · 09:30 · 22° Civil</text>
  <text x="324" y="159" font-family="system-ui,sans-serif" font-size="8" fill="#d97706" font-weight="700">3 días</text>

  <!-- Causa 3 -->
  <rect x="55" y="178" width="310" height="32" rx="6" fill="#ecfdf5" stroke="#a7f3d0"/>
  <circle cx="72" cy="194" r="6" fill="#10b981"/>
  <text x="68" y="198" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">✓</text>
  <text x="86" y="191" font-family="system-ui,sans-serif" font-size="10" fill="#065f46" font-weight="600">Pérez & Cía. · Escrito subido</text>
  <text x="86" y="204" font-family="system-ui,sans-serif" font-size="8" fill="#6b7280">15 may 14:22 · 5° Civil</text>

  <!-- Quick stats -->
  <rect x="55" y="218" width="98" height="20" rx="4" fill="#f0fdf4"/>
  <text x="60" y="232" font-family="system-ui,sans-serif" font-size="8" fill="#065f46" font-weight="700">14 activas</text>

  <rect x="161" y="218" width="98" height="20" rx="4" fill="#f0fdf4"/>
  <text x="166" y="232" font-family="system-ui,sans-serif" font-size="8" fill="#065f46" font-weight="700">0 vencidas</text>

  <rect x="267" y="218" width="98" height="20" rx="4" fill="#f0fdf4"/>
  <text x="272" y="232" font-family="system-ui,sans-serif" font-size="8" fill="#065f46" font-weight="700">8 nuevos leads</text>

  <!-- Right: Phone with lawyer agent chat -->
  <rect x="445" y="20" width="220" height="245" rx="22" fill="#1f2937" stroke="#0f172a" stroke-width="3"/>
  <rect x="460" y="36" width="190" height="213" rx="3" fill="#0b141a"/>

  <rect x="460" y="36" width="190" height="32" fill="#202c33"/>
  <circle cx="479" cy="52" r="9" fill="#059669"/>
  <text x="476" y="56" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">⚖</text>
  <text x="495" y="51" font-family="system-ui,sans-serif" font-size="9" font-weight="600" fill="#ffffff">Estudio Pérez · IA</text>
  <text x="495" y="61" font-family="system-ui,sans-serif" font-size="7" fill="#10b981">● 21:38 · respondiendo</text>

  <!-- Messages -->
  <rect x="468" y="80" width="155" height="42" rx="6" fill="#202c33"/>
  <text x="474" y="92" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">Hola, tuve un accidente</text>
  <text x="474" y="102" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">y el seguro no me quiere</text>
  <text x="474" y="113" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">pagar</text>

  <rect x="488" y="130" width="150" height="55" rx="6" fill="#005c4b"/>
  <text x="494" y="142" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff" font-weight="600">Hola 😊 Soy Sofía,</text>
  <text x="494" y="152" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">asistente del estudio.</text>
  <text x="494" y="164" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">¿Tienes parte policial?</text>
  <text x="494" y="174" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff">¿Daño aproximado?</text>

  <rect x="468" y="193" width="100" height="20" rx="6" fill="#202c33"/>
  <text x="474" y="207" font-family="system-ui,sans-serif" font-size="7" fill="#e5e7eb">Sí parte, ~$4M</text>

  <rect x="488" y="221" width="150" height="20" rx="6" fill="#10b981"/>
  <text x="494" y="234" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff" font-weight="700">✓ Reunión: jue 22 · 10:00</text>

  <!-- Connector -->
  <path d="M 380 140 Q 410 140 445 140" stroke="#10b981" stroke-width="2" stroke-dasharray="3 3" fill="none" opacity="0.5"/>

  <!-- PJUD badge -->
  <rect x="300" y="6" width="74" height="20" rx="10" fill="#047857"/>
  <text x="337" y="20" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff" text-anchor="middle">PJUD · OJV</text>
</svg>
