---
import { financing } from '../data/content';
import Badge from './ui/Badge.astro';
import Card from './ui/Card.astro';
import Button from './ui/Button.astro';
import DollarSign from './icons/DollarSign.astro';
import Percent from './icons/Percent.astro';
import ArrowRight from './icons/ArrowRight.astro';
---

<section id="financiamiento" class="py-24 bg-emerald-50">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="max-w-[640px] mb-14">
      <Badge class="mb-4">
        <DollarSign class="w-4 h-4" />
        <span>{financing.badge}</span>
      </Badge>

      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-4">
        {financing.title}{' '}
        <span class="text-emerald-700">{financing.titleHighlight}</span>{' '}
        {financing.titleEnd}
      </h2>

      <p class="text-gray-600 text-lg">{financing.description}</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 mb-12">
      {financing.cards.map((card) => (
        <Card dark={card.highlight}>
          <div class="p-6">
            <div
              class:list={[
                'inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full mb-4',
                card.highlight
                  ? 'bg-emerald-600 text-emerald-100'
                  : 'bg-emerald-50 text-emerald-700',
              ]}
            >
              <Percent class="w-3.5 h-3.5" />
              <span>{card.funded} financiado</span>
            </div>

            <h3
              class:list={[
                'font-semibold mb-1',
                card.highlight ? 'text-white' : 'text-gray-900',
              ]}
            >
              {card.instrument}
            </h3>
            <p
              class:list={[
                'text-sm mb-4',
                card.highlight ? 'text-emerald-200' : 'text-gray-500',
              ]}
            >
              {card.profile}
            </p>

            <div class="space-y-2">
              <div class="flex justify-between text-sm">
                <span class={card.highlight ? 'text-emerald-200' : 'text-gray-400'}>
                  Proyecto
                </span>
                <span
                  class:list={[
                    'font-medium',
                    card.highlight ? 'text-white' : 'text-gray-900',
                  ]}
                >
                  {card.projectCost}
                </span>
              </div>
              <div class="flex justify-between text-sm">
                <span class={card.highlight ? 'text-emerald-200' : 'text-gray-400'}>
                  Usted paga
                </span>
                <span
                  class:list={[
                    'font-bold text-lg',
                    card.highlight ? 'text-white' : 'text-emerald-700',
                  ]}
                >
                  {card.clientPays}
                </span>
              </div>
            </div>
          </div>
        </Card>
      ))}
    </div>

    <!-- CTA Banner -->
    <div class="bg-white rounded-xl border border-gray-100 p-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="font-semibold text-gray-900 text-lg mb-1">
          {financing.bannerTitle}
        </h3>
        <p class="text-sm text-gray-500">{financing.bannerDescription}</p>
      </div>
      <Button href="#contacto" size="lg" class="whitespace-nowrap shrink-0">
        {financing.bannerCta}
        <ArrowRight class="w-5 h-5" />
      </Button>
    </div>
  </div>
</section>
