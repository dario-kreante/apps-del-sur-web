---
import { contactCTA } from '../data/content';
import Button from './ui/Button.astro';
---

<section id="contacto" class="py-24 bg-emerald-800">
  <div class="max-w-[720px] mx-auto px-6 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight mb-4">
      {contactCTA.title}
    </h2>

    <p class="text-emerald-200 text-lg mb-8 max-w-[540px] mx-auto">
      {contactCTA.description}
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <Button href={contactCTA.ctaPrimaryHref} variant="whatsapp" size="lg">
        {contactCTA.ctaPrimary}
      </Button>
      <Button
        href={contactCTA.whatsappUrl}
        variant="secondary"
        size="lg"
        target="_blank"
      >
        {contactCTA.ctaWhatsApp}
      </Button>
    </div>

    <p class="mt-5 text-sm text-emerald-300">{contactCTA.subtext}</p>
  </div>
</section>
