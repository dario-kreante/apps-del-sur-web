---
interface Props {
  size?: number;
  class?: string;
}

const { size = 32, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 128 128"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <defs>
    <linearGradient id="ads-mark-gradient" x1="25" y1="113" x2="102" y2="18" gradientUnits="userSpaceOnUse">
      <stop stop-color="#064E3B" />
      <stop offset="0.56" stop-color="#059669" />
      <stop offset="1" stop-color="#7ED957" />
    </linearGradient>
  </defs>
  <path
    d="M64 8c29.6 0 53.6 23.6 53.6 52.7 0 17.1-8.8 32-19.2 44.1-8.1 9.4-17.6 17.3-26.8 22.1a15.6 15.6 0 0 1-15.2 0c-9.2-4.8-18.7-12.7-26.8-22.1C19.2 92.7 10.4 77.8 10.4 60.7 10.4 31.6 34.4 8 64 8Z"
    fill="url(#ads-mark-gradient)"
  />
  <path
    d="M29.3 69.5c5.9 8.2 16.4 13.2 29.6 13.2 20.1 0 36.6-11.5 50.7-25.5"
    stroke="white"
    stroke-width="10"
    stroke-linecap="round"
  />
  <path
    d="M91.7 85.4 117 76.6l-8.8 25.3-5.1-11.3-14 14-8.1-8.1 14-14-3.3 2.9Z"
    fill="white"
  />
  <rect x="33" y="56" width="17" height="28" rx="5" fill="white" opacity="0.7" />
  <rect x="55" y="45" width="17" height="39" rx="5" fill="white" opacity="0.86" />
  <rect x="78" y="30" width="17" height="54" rx="5" fill="white" />
</svg>
