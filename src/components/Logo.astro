---
interface Props {
  size?: number;
  class?: string;
}

const { size = 32, class: className } = Astro.props;
---

<!--
  Apps del Sur — Logomark

  Three terraced rows cascading downward:
  · Vineyard terraces on a Chilean hillside
  · A stylized "S" for Sur
  · Stacked data bars from a dashboard

  One form. Triple meaning. Reads at 16px.
-->
<svg
  width={size}
  height={size}
  viewBox="0 0 40 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <rect width="40" height="40" rx="10" fill="#047857"/>

  <!-- Three terraced rows — descending south, widening like hillside vineyards -->
  <rect x="14" y="10" width="12" height="4" rx="2" fill="white" opacity="0.55"/>
  <rect x="11" y="18" width="18" height="4" rx="2" fill="white" opacity="0.75"/>
  <rect x="8"  y="26" width="24" height="4" rx="2" fill="white"/>
</svg>
