---
interface Props {
  size?: number;
  class?: string;
}

const { size = 32, class: className } = Astro.props;
---

<!--
  Apps del Sur — Logomark

  Three terraced rows cascading downward:
  · Vineyard terraces on a Chilean hillside
  · A stylized "S" for Sur
  · Stacked data bars from a dashboard

  One form. Triple meaning. Reads at 16px.
-->
<svg
  width={size}
  height={size}
  viewBox="0 0 40 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <rect width="40" height="40" rx="10" fill="#047857"/>

  <!-- Three terraced rows — descending south, growing like real hillside terraces -->
  <rect x="13" y="9"  width="14" height="4" rx="2" fill="white" opacity="0.5"/>
  <rect x="10" y="17" width="20" height="5" rx="2.5" fill="white" opacity="0.75"/>
  <rect x="7"  y="26" width="26" height="6" rx="3" fill="white"/>
</svg>
