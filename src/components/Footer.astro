---
import { footer } from '../data/content';
import LogoLockup from './LogoLockup.astro';
import ArrowRight from './icons/ArrowRight.astro';
import Waves from './Waves.astro';
---

<footer class="relative overflow-hidden bg-gray-900 text-gray-400 py-12">
  <Waves position="top" class="opacity-50" />
  <div class="relative z-10 max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-7 gap-10 mb-10">
      <!-- Company Info -->
      <div class="md:col-span-2">
        <div class="mb-4">
          <LogoLockup variant="light" class="h-20 w-auto" />
        </div>
        <p class="text-sm leading-relaxed mb-4">{footer.tagline}</p>
        <p class="text-xs text-gray-500">
          Un producto de <span class="text-gray-400">{footer.companyLegal}</span>
        </p>
      </div>

      <!-- Agentes IA -->
      <div>
        <h4 class="font-semibold text-white text-sm mb-3">Agentes IA</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/agentes/" class="hover:text-white transition-colors">Todos los agentes</a></li>
          <li><a href="/agentes/agendamiento" class="hover:text-white transition-colors">Agendamiento</a></li>
          <li><a href="/agentes/whatsapp-atencion" class="hover:text-white transition-colors">Atención WhatsApp</a></li>
          <li><a href="/agentes/sdr-leads" class="hover:text-white transition-colors">SDR · Leads B2B</a></li>
          <li><a href="/agentes/retencion" class="hover:text-white transition-colors">Retención · Win-back</a></li>
          <li><a href="/agentes/compliance" class="hover:text-white transition-colors">Compliance · SAG</a></li>
          <li><a href="/agentes/abogados" class="hover:text-white transition-colors">Legal · Abogados</a></li>
          <li><a href="/agentes/cuota-mortuoria" class="hover:text-white transition-colors">Cuota Mortuoria · Funerario</a></li>
        </ul>
      </div>

      <!-- Por sector -->
      <div>
        <h4 class="font-semibold text-white text-sm mb-3">Por sector</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/agentes/sectores/vinas" class="hover:text-white transition-colors">Viñas y Agro</a></li>
          <li><a href="/agentes/sectores/clinicas" class="hover:text-white transition-colors">Clínicas</a></li>
          <li><a href="/agentes/sectores/hoteles-turismo" class="hover:text-white transition-colors">Hoteles y Turismo</a></li>
          <li><a href="/agentes/sectores/abogados" class="hover:text-white transition-colors">Abogados</a></li>
          <li><a href="/agentes/sectores/inmobiliarias" class="hover:text-white transition-colors">Inmobiliarias</a></li>
          <li><a href="/agentes/sectores/constructoras" class="hover:text-white transition-colors">Constructoras</a></li>
          <li><a href="/agentes/sectores/clubes-deportivos" class="hover:text-white transition-colors">Clubes y Gimnasios</a></li>
          <li><a href="/agentes/sectores/funerarias" class="hover:text-white transition-colors">Funerarias</a></li>
        </ul>
      </div>

      <!-- Solution Links -->
      <div>
        <h4 class="font-semibold text-white text-sm mb-3">Soluciones</h4>
        <ul class="space-y-2 text-sm">
          {footer.solutionLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="hover:text-white transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Regions -->
      <div>
        <h4 class="font-semibold text-white text-sm mb-3">Regiones</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/regiones/ohiggins" class="hover:text-white transition-colors">O'Higgins</a></li>
          <li><a href="/regiones/maule" class="hover:text-white transition-colors">Maule</a></li>
          <li><a href="/regiones/nuble" class="hover:text-white transition-colors">Ñuble</a></li>
          <li><a href="/regiones/biobio" class="hover:text-white transition-colors">Biobío</a></li>
          <li><a href="/regiones/araucania" class="hover:text-white transition-colors">Araucanía</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-white text-sm mb-3">Contacto</h4>
        <ul class="space-y-2.5 text-sm">
          <li>
            <span class="text-gray-500 text-xs block">{footer.contact.name}</span>
            <a href={footer.contact.phoneHref} class="hover:text-white transition-colors">
              {footer.contact.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${footer.contact.email}`}
              class="hover:text-white transition-colors"
            >
              {footer.contact.email}
            </a>
          </li>
          <li>
            <a
              href={footer.contact.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-emerald-400 hover:text-emerald-300 transition-colors font-medium"
            >
              WhatsApp directo
              <ArrowRight class="w-4 h-4" />
            </a>
          </li>
        </ul>

        <div class="mt-5 pt-4 border-t border-gray-800">
          <a
            href="#contacto"
            class="inline-flex items-center gap-1.5 text-sm text-white hover:text-emerald-400 transition-colors font-medium"
          >
            Solicitar diagnóstico gratuito
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>

    <hr class="border-gray-800 mb-6" />

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-500">
      <p>{footer.copyright}</p>
      <div class="flex gap-6">
        <span>{footer.madeIn}</span>
        <a href="#" class="hover:text-white transition-colors">Privacidad</a>
        <a href="#" class="hover:text-white transition-colors">Términos</a>
      </div>
    </div>
  </div>
</footer>
