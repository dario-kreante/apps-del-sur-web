---
import { footer } from '../data/content';
import ArrowRight from './icons/ArrowRight.astro';
---

<footer class="bg-gray-900 text-gray-400 py-12">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-5 gap-10 mb-10">
      <!-- Company Info -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg bg-emerald-700 flex items-center justify-center">
            <span class="text-white font-bold text-sm">AS</span>
          </div>
          <span class="font-semibold text-white text-[15px]">
            {footer.companyName}
          </span>
        </div>
        <p class="text-sm leading-relaxed mb-4">{footer.tagline}</p>
        <p class="text-xs text-gray-500">
          Un producto de <span class="text-gray-400">{footer.companyLegal}</span>
        </p>
      </div>

      <!-- Solution Links -->
      <div>
        <h4 class="font-semibold text-white text-sm mb-3">Solución</h4>
        <ul class="space-y-2 text-sm">
          {footer.solutionLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="hover:text-white transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Regions -->
      <div>
        <h4 class="font-semibold text-white text-sm mb-3">Regiones</h4>
        <ul class="space-y-2 text-sm">
          {footer.regions.map((region) => (
            <li>{region}</li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-white text-sm mb-3">Contacto</h4>
        <ul class="space-y-2.5 text-sm">
          <li>
            <span class="text-gray-500 text-xs block">{footer.contact.name}</span>
            <a href={footer.contact.phoneHref} class="hover:text-white transition-colors">
              {footer.contact.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${footer.contact.email}`}
              class="hover:text-white transition-colors"
            >
              {footer.contact.email}
            </a>
          </li>
          <li>
            <a
              href={footer.contact.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-emerald-400 hover:text-emerald-300 transition-colors font-medium"
            >
              WhatsApp directo
              <ArrowRight class="w-4 h-4" />
            </a>
          </li>
        </ul>

        <div class="mt-5 pt-4 border-t border-gray-800">
          <a
            href="#contacto"
            class="inline-flex items-center gap-1.5 text-sm text-white hover:text-emerald-400 transition-colors font-medium"
          >
            Solicitar diagnóstico gratuito
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>

    <hr class="border-gray-800 mb-6" />

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-500">
      <p>{footer.copyright}</p>
      <div class="flex gap-6">
        <span>{footer.madeIn}</span>
        <a href="#" class="hover:text-white transition-colors">Privacidad</a>
        <a href="#" class="hover:text-white transition-colors">Términos</a>
      </div>
    </div>
  </div>
</footer>
