---
interface Props {
  variant?: 'default' | 'light';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const src =
  variant === 'light'
    ? '/brand/logo-horizontal-dark.png'
    : '/brand/logo-horizontal.png';
---

<img
  src={src}
  alt="Apps del Sur"
  class={className}
  loading="eager"
  decoding="async"
  style="object-fit: contain; object-position: left center;"
/>
