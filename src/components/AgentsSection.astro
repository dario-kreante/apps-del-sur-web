---
import Badge from './ui/Badge.astro';
import Button from './ui/Button.astro';
import SectionHeader from './ui/SectionHeader.astro';
import ArrowRight from './icons/ArrowRight.astro';
import Sparkle from './icons/Sparkle.astro';
import { agentPages } from '../data/agentes';

const featuredSlugs = ['agendamiento', 'whatsapp-atencion', 'sdr-leads'];
const agentes = featuredSlugs
  .map((slug) => agentPages[slug])
  .filter(Boolean);
---

<section id="agentes" class="py-24 bg-white border-t border-gray-100">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center mb-4">
      <Badge>🟢 Nuevo · Agentes IA por WhatsApp</Badge>
    </div>

    <SectionHeader
      title="Y ahora también: agentes de IA que atienden por WhatsApp 24/7"
      description="El cuaderno de campo registra lo que pasa en terreno. Los agentes IA atienden a sus clientes, agendan, califican leads y cobran — mientras usted duerme. 98% de apertura, respuesta en segundos, sin contratar más gente."
      centered
      class="mb-8"
    />

    <figure class="relative max-w-[980px] mx-auto mb-14 overflow-hidden rounded-2xl border border-gray-200 bg-gray-50 shadow-sm">
      <img
        src="/images/agente-ia-whatsapp-accion.png"
        alt="Agente de IA operando conversaciones y flujos de atención por WhatsApp"
        class="w-full aspect-[16/9] object-cover"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute left-4 top-4 hidden sm:inline-flex items-center gap-2 rounded-full bg-white/90 px-3 py-1.5 text-xs font-medium text-emerald-800 shadow-sm ring-1 ring-emerald-100 backdrop-blur">
        <Sparkle class="w-3.5 h-3.5" />
        Agente en acción
      </div>
    </figure>

    <!-- Strip de métricas -->
    <div class="grid grid-cols-3 max-w-[640px] mx-auto gap-4 text-center mb-14">
      <div>
        <div class="text-3xl md:text-4xl font-bold text-emerald-700">98%</div>
        <div class="text-xs text-gray-500 mt-1">Apertura WhatsApp Chile</div>
      </div>
      <div>
        <div class="text-3xl md:text-4xl font-bold text-emerald-700">&lt;30s</div>
        <div class="text-xs text-gray-500 mt-1">Tiempo de respuesta</div>
      </div>
      <div>
        <div class="text-3xl md:text-4xl font-bold text-emerald-700">2-6 sem</div>
        <div class="text-xs text-gray-500 mt-1">Implementación</div>
      </div>
    </div>

    <!-- Grid de verticales destacadas -->
    <div class="grid md:grid-cols-3 gap-5 mb-8">
      {agentes.map((a) => (
        <a
          href={a.url}
          class="group rounded-2xl bg-white border border-gray-200 p-6 hover:border-emerald-300 hover:shadow-lg transition-all flex flex-col"
        >
          <div class="flex items-start justify-between mb-4">
            <div class="text-4xl">{a.emoji}</div>
            <div class="inline-flex items-center gap-1.5 bg-emerald-100 text-emerald-800 px-2.5 py-1 rounded-full text-xs font-medium">
              <Sparkle class="w-3 h-3" />
              Disponible
            </div>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-emerald-700 transition-colors">
            {a.name}
          </h3>
          <p class="text-sm text-gray-600 mb-4 leading-relaxed">{a.shortDescription}</p>

          <div class="mb-4">
            <div class="text-xs text-gray-400 uppercase tracking-wider mb-2">Para</div>
            <div class="flex flex-wrap gap-1.5">
              {a.targetIndustries.slice(0, 3).map((ind) => (
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">{ind}</span>
              ))}
            </div>
          </div>

          <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between">
            <div>
              <div class="text-xs text-gray-500">Desde</div>
              <div class="font-semibold text-emerald-700 text-sm">{a.pricing.saas[0]?.price || a.pricing.ventaUnica[0]?.price}</div>
            </div>
            <div class="text-emerald-700 font-medium text-sm inline-flex items-center gap-1.5 group-hover:gap-2.5 transition-all">
              Ver
              <ArrowRight class="w-4 h-4" />
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Ver más → hub de agentes -->
    <div class="text-center mb-14">
      <a
        href="/agentes/"
        class="inline-flex items-center gap-2 text-emerald-700 hover:text-emerald-800 font-medium text-[15px] transition-colors group"
      >
        Ver los 7 agentes disponibles
        <ArrowRight class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" />
      </a>
    </div>

    <!-- Bloque CTA final -->
    <div class="rounded-2xl bg-emerald-50 border border-emerald-100 p-8 md:p-10 text-center">
      <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3 tracking-tight">
        ¿Qué agente puede atender por usted?
      </h3>
      <p class="text-gray-600 text-base md:text-lg max-w-[640px] mx-auto mb-6">
        Cada agente está diseñado para un dolor concreto de una vertical específica — no son chatbots genéricos.
      </p>
      <div class="flex flex-col lg:flex-row gap-3 justify-center mb-4 max-w-[680px] mx-auto">
        <Button href="/agentes/" size="lg" class="w-full lg:w-auto !whitespace-normal text-center">
          Ver catálogo completo de Agentes IA
          <ArrowRight class="w-5 h-5 shrink-0" />
        </Button>
        <Button
          href="/diagnostico-madurez-ia/?source=home-agentes"
          variant="outline"
          size="lg"
          class="w-full lg:w-auto !whitespace-normal text-center"
        >
          Diagnosticar mi madurez IA (gratis · 6 min)
        </Button>
      </div>
      <p class="text-xs text-gray-500">
        Financiable con Kit Digital, SERCOTEC CRECE y CORFO Digitalización Pyme · cubre 60–100% del costo.
      </p>
    </div>
  </div>
</section>
