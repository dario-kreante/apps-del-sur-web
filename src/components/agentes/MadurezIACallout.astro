---
import Button from '../ui/Button.astro';
import Sparkle from '../icons/Sparkle.astro';
import ArrowRight from '../icons/ArrowRight.astro';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const href = `/diagnostico-madurez-ia/?source=agentes-${slug}`;
---

<section class="py-16 bg-white">
  <div class="max-w-[1100px] mx-auto px-6">
    <div class="rounded-2xl bg-gradient-to-br from-emerald-700 to-emerald-900 p-8 md:p-12 text-white relative overflow-hidden">
      <!-- Decorative circle -->
      <div class="absolute -top-20 -right-20 w-64 h-64 rounded-full bg-emerald-500/20 blur-3xl"></div>
      <div class="absolute -bottom-20 -left-20 w-64 h-64 rounded-full bg-emerald-400/10 blur-3xl"></div>

      <div class="relative z-10 flex flex-col md:flex-row md:items-center gap-8">
        <div class="flex-1">
          <div class="inline-flex items-center gap-1.5 bg-emerald-500/20 text-emerald-100 px-3 py-1 rounded-full text-xs font-medium mb-4 border border-emerald-400/30">
            <Sparkle class="w-3.5 h-3.5" />
            Gratis · 6 min · 12 preguntas
          </div>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-3">
            ¿No sabe por dónde partir con IA?
          </h2>
          <p class="text-emerald-100 text-base md:text-lg leading-relaxed max-w-[560px]">
            Antes de comprar un agente, evalúe en qué etapa de madurez IA está su empresa. Nuestro diagnóstico le entrega un plan de acción personalizado en 6 minutos.
          </p>
        </div>

        <div class="shrink-0">
          <Button href={href} variant="whatsapp" size="lg" class="shadow-lg">
            Hacer diagnóstico
            <ArrowRight class="w-5 h-5" />
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
