---
import type { HowStep } from '../../data/agentes';
import SectionHeader from '../ui/SectionHeader.astro';

interface Props {
  steps: HowStep[];
}

const { steps } = Astro.props;
---

<section class="py-20 bg-white">
  <div class="max-w-[1200px] mx-auto px-6">
    <SectionHeader
      label="Cómo funciona"
      title="De la primera conversación a la primera venta"
      description="Implementamos en 2 a 6 semanas según el plan. Sin código, sin servidores que mantener."
      centered
    />

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mt-8 relative">
      {steps.map((step, i) => (
        <div class="relative">
          <div class="bg-gray-50 rounded-xl border border-gray-100 p-6 h-full hover:border-emerald-200 hover:shadow-sm transition-all">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full bg-emerald-700 text-white flex items-center justify-center font-semibold text-sm shrink-0">
                {step.step}
              </div>
              <h3 class="font-semibold text-gray-900 text-base leading-tight">{step.title}</h3>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed">{step.description}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-12 -right-3 z-10 text-emerald-300">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
