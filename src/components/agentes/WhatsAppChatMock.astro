---
import type { ChatMessage } from '../../data/agentes';

interface Props {
  title: string;
  contact: string;
  messages: ChatMessage[];
  class?: string;
}

const { title, contact, messages, class: className } = Astro.props;
---

<div class:list={['w-full max-w-[400px] mx-auto', className]}>
  {title && (
    <p class="text-sm font-medium text-emerald-700 mb-3 text-center">{title}</p>
  )}

  <div class="rounded-2xl bg-[#0b141a] shadow-xl overflow-hidden border border-gray-200">
    <!-- WhatsApp header -->
    <div class="bg-[#202c33] px-4 py-3 flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-emerald-600 flex items-center justify-center text-white font-semibold text-sm shrink-0">
        IA
      </div>
      <div class="flex-1 min-w-0">
        <div class="text-white font-medium text-sm truncate">{contact}</div>
        <div class="text-[#8696a0] text-xs flex items-center gap-1">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
          en línea
        </div>
      </div>
      <svg class="w-5 h-5 text-[#8696a0]" viewBox="0 0 24 24" fill="currentColor">
        <path d="M15.5 12c0 .85-.35 1.62-.9 2.18l-1.42-1.42c.2-.23.32-.52.32-.86 0-.78-.6-1.42-1.4-1.5L10.68 9c.4-.16.85-.25 1.32-.25 1.93 0 3.5 1.57 3.5 3.25z"/>
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" opacity="0.6"/>
      </svg>
    </div>

    <!-- WhatsApp background pattern -->
    <div class="relative bg-[#0b141a] px-3 py-4 min-h-[420px]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.03) 1px, transparent 0); background-size: 20px 20px;">
      <div class="space-y-2">
        {messages.map((msg) => (
          <div class:list={['flex', msg.from === 'cliente' ? 'justify-start' : 'justify-end']}>
            <div
              class:list={[
                'max-w-[80%] px-3 py-2 rounded-lg text-[13px] leading-snug shadow whitespace-pre-line',
                msg.from === 'cliente'
                  ? 'bg-[#202c33] text-gray-100 rounded-tl-sm'
                  : 'bg-[#005c4b] text-white rounded-tr-sm',
              ]}
            >
              <div>{msg.text}</div>
              {msg.time && (
                <div class="text-[10px] text-[#8696a0] text-right mt-0.5">{msg.time}</div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Input bar (fake) -->
    <div class="bg-[#202c33] px-3 py-2 flex items-center gap-2">
      <div class="flex-1 bg-[#2a3942] rounded-full px-4 py-2 text-[#8696a0] text-xs">
        Mensaje
      </div>
      <div class="w-9 h-9 rounded-full bg-emerald-600 flex items-center justify-center">
        <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
        </svg>
      </div>
    </div>
  </div>
</div>
