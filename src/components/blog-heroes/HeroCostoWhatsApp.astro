---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Rangos de inversión para automatización de WhatsApp empresarial">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>

  <!-- Title -->
  <text x="400" y="28" text-anchor="middle" font-family="system-ui,sans-serif" font-size="13" font-weight="700" fill="#1f2937">Automatización WhatsApp — Niveles de Inversión</text>

  <!-- WhatsApp icon at top center -->
  <circle cx="400" cy="22" r="0" fill="none"/>

  <!-- Three levels as horizontal bars with WhatsApp-style bubbles -->
  <!-- Level 1: Respuestas Automáticas -->
  <rect x="40" y="48" width="720" height="56" rx="10" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
  <!-- Chat bubble -->
  <rect x="56" y="56" width="36" height="36" rx="8" fill="#047857"/>
  <text x="74" y="72" text-anchor="middle" font-family="system-ui,sans-serif" font-size="8" fill="#ffffff" font-weight="600">FAQ</text>
  <text x="74" y="84" text-anchor="middle" font-family="system-ui,sans-serif" font-size="7" fill="#d1fae5">auto</text>

  <text x="110" y="70" font-family="system-ui,sans-serif" font-size="13" font-weight="700" fill="#047857">Respuestas Automáticas</text>
  <text x="110" y="88" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">Menú de opciones • Respuestas predefinidas • Horario de atención • Derivación a humano</text>
  <text x="640" y="72" text-anchor="middle" font-family="system-ui,sans-serif" font-size="20" font-weight="800" fill="#047857">20–100 UF</text>
  <text x="640" y="90" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#6b7280">+ ~$15.000/mes API</text>

  <!-- Level 2: Integración CRM -->
  <rect x="40" y="116" width="720" height="56" rx="10" fill="#ffffff" stroke="#059669" stroke-width="2"/>
  <!-- CRM bubble -->
  <rect x="56" y="124" width="36" height="36" rx="8" fill="#059669"/>
  <text x="74" y="140" text-anchor="middle" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff" font-weight="600">CRM</text>
  <text x="74" y="152" text-anchor="middle" font-family="system-ui,sans-serif" font-size="7" fill="#d1fae5">sync</text>

  <text x="110" y="138" font-family="system-ui,sans-serif" font-size="13" font-weight="700" fill="#059669">Integración CRM</text>
  <text x="110" y="156" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">Base de clientes • Seguimiento conversaciones • Métricas • Multi-agente • Notificaciones</text>
  <text x="640" y="140" text-anchor="middle" font-family="system-ui,sans-serif" font-size="20" font-weight="800" fill="#059669">100–500 UF</text>
  <text x="640" y="158" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#6b7280">+ $30-80K/mes plataforma</text>

  <!-- Level 3: Agente IA -->
  <rect x="40" y="184" width="720" height="56" rx="10" fill="#ffffff" stroke="#10b981" stroke-width="1.5"/>
  <!-- AI bubble -->
  <rect x="56" y="192" width="36" height="36" rx="8" fill="#10b981"/>
  <text x="74" y="208" text-anchor="middle" font-family="system-ui,sans-serif" font-size="7" fill="#ffffff" font-weight="600">AI</text>
  <text x="74" y="220" text-anchor="middle" font-family="system-ui,sans-serif" font-size="7" fill="#d1fae5">agent</text>

  <text x="110" y="206" font-family="system-ui,sans-serif" font-size="13" font-weight="700" fill="#10b981">Agente IA Completo</text>
  <text x="110" y="224" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">Comprensión lenguaje natural • Cotizaciones automáticas • Agenda citas • Aprende del negocio</text>
  <text x="640" y="208" text-anchor="middle" font-family="system-ui,sans-serif" font-size="20" font-weight="800" fill="#10b981">500–2.000 UF</text>
  <text x="640" y="226" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#6b7280">+ costos API según volumen</text>

  <!-- Footer -->
  <text x="400" y="254" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#9ca3af">* Rangos referenciales en UF. Costos operativos mensuales adicionales según volumen de mensajes.</text>
</svg>
