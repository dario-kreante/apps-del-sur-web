---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Certificacion de sustentabilidad con documentos de cumplimiento">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>

  <!-- Central badge/seal -->
  <g transform="translate(400, 130)">
    <!-- Radiating lines -->
    <g stroke="#a7f3d0" stroke-width="2">
      <line x1="0" y1="-70" x2="0" y2="-55"/>
      <line x1="50" y1="-50" x2="39" y2="-39"/>
      <line x1="70" y1="0" x2="55" y2="0"/>
      <line x1="50" y1="50" x2="39" y2="39"/>
      <line x1="0" y1="70" x2="0" y2="55"/>
      <line x1="-50" y1="50" x2="-39" y2="39"/>
      <line x1="-70" y1="0" x2="-55" y2="0"/>
      <line x1="-50" y1="-50" x2="-39" y2="-39"/>
    </g>
    <!-- Outer scalloped edge -->
    <circle r="52" fill="#047857"/>
    <circle r="48" fill="none" stroke="#34d399" stroke-width="1.5" stroke-dasharray="6,3"/>
    <circle r="42" fill="#059669"/>
    <!-- Checkmark -->
    <polyline points="-14,2 -4,14 18,-12" fill="none" stroke="#ffffff" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
    <!-- Text around badge -->
    <text y="-22" text-anchor="middle" font-family="system-ui,sans-serif" font-size="8" font-weight="700" fill="#d1fae5" letter-spacing="3">CERTIFICADO</text>
  </g>

  <!-- Document 1: top-left -->
  <g transform="translate(140, 60)">
    <rect x="-30" y="-35" width="60" height="70" rx="4" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
    <rect x="-20" y="-25" width="30" height="4" rx="1" fill="#d1fae5"/>
    <rect x="-20" y="-16" width="40" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="-9" width="35" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="-2" width="38" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="5" width="25" height="3" rx="1" fill="#e5e7eb"/>
    <!-- Green checkmark -->
    <circle cx="16" cy="20" r="9" fill="#d1fae5"/>
    <polyline points="10,20 14,25 23,15" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    <text y="55" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#047857">Trazabilidad</text>
  </g>

  <!-- Document 2: top-right -->
  <g transform="translate(660, 60)">
    <rect x="-30" y="-35" width="60" height="70" rx="4" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
    <rect x="-20" y="-25" width="30" height="4" rx="1" fill="#d1fae5"/>
    <rect x="-20" y="-16" width="40" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="-9" width="35" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="-2" width="38" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="5" width="25" height="3" rx="1" fill="#e5e7eb"/>
    <circle cx="16" cy="20" r="9" fill="#d1fae5"/>
    <polyline points="10,20 14,25 23,15" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    <text y="55" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#047857">Medio Ambiente</text>
  </g>

  <!-- Document 3: bottom-left -->
  <g transform="translate(175, 190)">
    <rect x="-30" y="-35" width="60" height="70" rx="4" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
    <rect x="-20" y="-25" width="30" height="4" rx="1" fill="#d1fae5"/>
    <rect x="-20" y="-16" width="40" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="-9" width="35" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="-2" width="38" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="5" width="25" height="3" rx="1" fill="#e5e7eb"/>
    <circle cx="16" cy="20" r="9" fill="#d1fae5"/>
    <polyline points="10,20 14,25 23,15" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    <text y="55" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#047857">Seguridad</text>
  </g>

  <!-- Document 4: bottom-right -->
  <g transform="translate(625, 190)">
    <rect x="-30" y="-35" width="60" height="70" rx="4" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
    <rect x="-20" y="-25" width="30" height="4" rx="1" fill="#d1fae5"/>
    <rect x="-20" y="-16" width="40" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="-9" width="35" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="-2" width="38" height="3" rx="1" fill="#e5e7eb"/>
    <rect x="-20" y="5" width="25" height="3" rx="1" fill="#e5e7eb"/>
    <circle cx="16" cy="20" r="9" fill="#d1fae5"/>
    <polyline points="10,20 14,25 23,15" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    <text y="55" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#047857">BPA</text>
  </g>
</svg>
