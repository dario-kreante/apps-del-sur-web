---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Cuaderno de Campo digital en smartphone">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>
  <!-- Phone frame -->
  <rect x="310" y="20" width="180" height="220" rx="18" fill="#1f2937"/>
  <rect x="318" y="38" width="164" height="184" rx="4" fill="#ffffff"/>
  <!-- Status bar -->
  <rect x="318" y="38" width="164" height="18" rx="4" fill="#d1fae5"/>
  <circle cx="334" cy="47" r="3" fill="#059669"/>
  <rect x="342" y="44" width="20" height="6" rx="2" fill="#059669"/>
  <rect x="456" y="44" width="18" height="6" rx="2" fill="#10b981"/>
  <!-- Title bar -->
  <rect x="318" y="56" width="164" height="22" fill="#047857"/>
  <text x="400" y="71" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#ffffff">Cuaderno de Campo</text>
  <!-- Checklist -->
  <rect x="332" y="88" width="14" height="14" rx="3" fill="#059669"/>
  <polyline points="335,95 338,99 343,91" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  <rect x="352" y="90" width="80" height="8" rx="2" fill="#a7f3d0"/>
  <text x="355" y="97" font-family="system-ui,sans-serif" font-size="7" fill="#047857">Poda completada</text>

  <rect x="332" y="110" width="14" height="14" rx="3" fill="#059669"/>
  <polyline points="335,117 338,121 343,113" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  <rect x="352" y="112" width="95" height="8" rx="2" fill="#a7f3d0"/>
  <text x="355" y="119" font-family="system-ui,sans-serif" font-size="7" fill="#047857">Riego programado</text>

  <rect x="332" y="132" width="14" height="14" rx="3" fill="#d1fae5" stroke="#10b981" stroke-width="1.5"/>
  <rect x="352" y="134" width="70" height="8" rx="2" fill="#d1fae5"/>
  <text x="355" y="141" font-family="system-ui,sans-serif" font-size="7" fill="#6ee7b7">Fertilizacion</text>

  <!-- GPS indicator -->
  <rect x="328" y="160" width="144" height="20" rx="6" fill="#d1fae5"/>
  <circle cx="342" cy="170" r="5" fill="#059669"/>
  <circle cx="342" cy="170" r="2" fill="#ffffff"/>
  <text x="352" y="173" font-family="monospace" font-size="7" fill="#047857">-35.42, -71.65</text>

  <!-- Decorative field rows left -->
  <rect x="60" y="140" width="180" height="6" rx="3" fill="#a7f3d0"/>
  <rect x="80" y="155" width="160" height="6" rx="3" fill="#d1fae5"/>
  <rect x="70" y="170" width="170" height="6" rx="3" fill="#a7f3d0"/>
  <rect x="90" y="185" width="150" height="6" rx="3" fill="#d1fae5"/>

  <!-- Decorative field rows right -->
  <rect x="560" y="140" width="180" height="6" rx="3" fill="#a7f3d0"/>
  <rect x="560" y="155" width="160" height="6" rx="3" fill="#d1fae5"/>
  <rect x="560" y="170" width="170" height="6" rx="3" fill="#a7f3d0"/>
  <rect x="560" y="185" width="150" height="6" rx="3" fill="#d1fae5"/>

  <!-- Notch -->
  <rect x="370" y="20" width="60" height="12" rx="6" fill="#1f2937"/>
</svg>
