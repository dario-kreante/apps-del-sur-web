---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Codex de OpenAI ejecutando tareas dentro de las herramientas que ya usa una pyme chilena">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>

  <text x="400" y="28" text-anchor="middle" font-family="system-ui,sans-serif" font-size="13" font-weight="700" fill="#1f2937">Codex (OpenAI) en tu pyme</text>

  <!-- Left: Owner -->
  <g transform="translate(40, 60)">
    <circle cx="60" cy="40" r="28" fill="#047857"/>
    <text x="60" y="46" text-anchor="middle" font-family="system-ui,sans-serif" font-size="24" fill="#ffffff">👤</text>
    <text x="60" y="100" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" font-weight="600" fill="#1f2937">Tú</text>
    <text x="60" y="115" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#6b7280">"Conciliame las</text>
    <text x="60" y="127" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#6b7280">facturas del mes"</text>
  </g>

  <!-- Arrow 1 -->
  <line x1="160" y1="100" x2="220" y2="100" stroke="#047857" stroke-width="2"/>
  <polygon points="215,95 225,100 215,105" fill="#047857"/>

  <!-- Center: Codex agent -->
  <g transform="translate(240, 50)">
    <rect x="0" y="0" width="160" height="160" rx="14" fill="#ffffff" stroke="#059669" stroke-width="2"/>
    <rect x="0" y="0" width="160" height="32" rx="14" fill="#059669"/>
    <text x="80" y="22" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="700" fill="#ffffff">Codex</text>
    <!-- Code lines -->
    <rect x="14" y="46" width="120" height="6" rx="2" fill="#a7f3d0"/>
    <rect x="14" y="58" width="90" height="6" rx="2" fill="#a7f3d0"/>
    <rect x="14" y="70" width="110" height="6" rx="2" fill="#6ee7b7"/>
    <rect x="14" y="82" width="80" height="6" rx="2" fill="#a7f3d0"/>
    <rect x="14" y="94" width="100" height="6" rx="2" fill="#6ee7b7"/>
    <!-- Gear -->
    <circle cx="80" cy="130" r="16" fill="#059669" opacity="0.15"/>
    <text x="80" y="137" text-anchor="middle" font-family="system-ui,sans-serif" font-size="16" fill="#059669">⚙</text>
  </g>

  <!-- Arrow 2 -->
  <line x1="410" y1="100" x2="470" y2="100" stroke="#047857" stroke-width="2"/>
  <polygon points="465,95 475,100 465,105" fill="#047857"/>

  <!-- Right: Apps/integrations -->
  <g transform="translate(490, 40)">
    <!-- Excel -->
    <rect x="0" y="0" width="80" height="60" rx="8" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
    <rect x="0" y="0" width="80" height="14" rx="8" fill="#16a34a"/>
    <text x="40" y="10" text-anchor="middle" font-family="system-ui,sans-serif" font-size="8" font-weight="700" fill="#ffffff">EXCEL</text>
    <line x1="10" y1="28" x2="70" y2="28" stroke="#d1d5db" stroke-width="1"/>
    <line x1="10" y1="38" x2="70" y2="38" stroke="#d1d5db" stroke-width="1"/>
    <line x1="10" y1="48" x2="70" y2="48" stroke="#d1d5db" stroke-width="1"/>

    <!-- WhatsApp -->
    <rect x="100" y="0" width="80" height="60" rx="8" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
    <rect x="100" y="0" width="80" height="14" rx="8" fill="#25D366"/>
    <text x="140" y="10" text-anchor="middle" font-family="system-ui,sans-serif" font-size="7" font-weight="700" fill="#ffffff">WHATSAPP</text>
    <text x="140" y="40" text-anchor="middle" font-family="system-ui,sans-serif" font-size="18" fill="#25D366">💬</text>

    <!-- Gmail -->
    <rect x="0" y="80" width="80" height="60" rx="8" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
    <rect x="0" y="80" width="80" height="14" rx="8" fill="#EA4335"/>
    <text x="40" y="90" text-anchor="middle" font-family="system-ui,sans-serif" font-size="8" font-weight="700" fill="#ffffff">GMAIL</text>
    <text x="40" y="120" text-anchor="middle" font-family="system-ui,sans-serif" font-size="16" fill="#EA4335">✉</text>

    <!-- Banco / SII -->
    <rect x="100" y="80" width="80" height="60" rx="8" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
    <rect x="100" y="80" width="80" height="14" rx="8" fill="#1f2937"/>
    <text x="140" y="90" text-anchor="middle" font-family="system-ui,sans-serif" font-size="8" font-weight="700" fill="#ffffff">SII / BANCO</text>
    <text x="140" y="120" text-anchor="middle" font-family="system-ui,sans-serif" font-size="14" fill="#1f2937">🏦</text>
  </g>

  <!-- Bottom caption -->
  <text x="400" y="230" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" font-weight="600" fill="#047857">Lenguaje natural · Ejecuta en tus apps · Tú apruebas</text>
  <text x="400" y="246" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#9ca3af">Sin programar · Sin contratar a un desarrollador · 2025–2026</text>
</svg>
