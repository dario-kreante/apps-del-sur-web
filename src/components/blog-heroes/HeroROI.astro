---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 320" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Calculadora de ROI de proyectos de IA en pymes chilenas: inversión, ahorro y retorno en pesos">
  <defs>
    <linearGradient id="roi-bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#ecfdf5"/>
      <stop offset="100%" stop-color="#f0fdf4"/>
    </linearGradient>
    <linearGradient id="roi-gauge" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="#dc2626"/>
      <stop offset="50%" stop-color="#f59e0b"/>
      <stop offset="100%" stop-color="#16a34a"/>
    </linearGradient>
  </defs>

  <rect width="800" height="320" rx="14" fill="url(#roi-bg)"/>

  <text x="400" y="34" text-anchor="middle" font-family="system-ui,sans-serif" font-size="14" font-weight="700" fill="#064e3b">El ROI real de un proyecto de IA en una pyme chilena</text>

  <!-- Left side: Investment box -->
  <rect x="40" y="70" width="180" height="200" rx="12" fill="#fff" stroke="#10b981" stroke-width="2"/>
  <text x="130" y="100" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" font-weight="700" fill="#064e3b">INVERSIÓN INICIAL</text>
  <text x="130" y="140" text-anchor="middle" font-family="system-ui,sans-serif" font-size="28" font-weight="800" fill="#064e3b">$8M</text>
  <text x="130" y="160" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">venta única</text>
  <!-- Subsidy bar -->
  <rect x="60" y="180" width="140" height="14" rx="3" fill="#e5e7eb"/>
  <rect x="60" y="180" width="84" height="14" rx="3" fill="#16a34a"/>
  <text x="60" y="208" font-family="system-ui,sans-serif" font-size="9" font-weight="700" fill="#16a34a">60% subsidio CORFO</text>
  <text x="130" y="232" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" font-weight="800" fill="#064e3b">Copago real: $3,2M</text>
  <text x="130" y="252" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#6b7280">(lo que paga la pyme)</text>

  <!-- Arrow -->
  <path d="M 240,165 L 290,165" stroke="#064e3b" stroke-width="2.5" marker-end="url(#roi-arrow)"/>
  <defs><marker id="roi-arrow" markerWidth="10" markerHeight="10" refX="9" refY="5" orient="auto"><polygon points="0,0 10,5 0,10" fill="#064e3b"/></marker></defs>
  <text x="265" y="155" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#6b7280">12 meses</text>

  <!-- Middle: Savings stack -->
  <rect x="310" y="70" width="200" height="200" rx="12" fill="#fff" stroke="#10b981" stroke-width="2"/>
  <text x="410" y="100" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" font-weight="700" fill="#064e3b">AHORRO ANUAL</text>

  <rect x="325" y="115" width="170" height="28" rx="4" fill="#dcfce7"/>
  <text x="335" y="133" font-family="system-ui,sans-serif" font-size="10" font-weight="600" fill="#14532d">Tiempo administrativo</text>
  <text x="487" y="133" text-anchor="end" font-family="system-ui,sans-serif" font-size="11" font-weight="800" fill="#14532d">$3,6M</text>

  <rect x="325" y="148" width="170" height="28" rx="4" fill="#dcfce7"/>
  <text x="335" y="166" font-family="system-ui,sans-serif" font-size="10" font-weight="600" fill="#14532d">Reducción de errores</text>
  <text x="487" y="166" text-anchor="end" font-family="system-ui,sans-serif" font-size="11" font-weight="800" fill="#14532d">$1,8M</text>

  <rect x="325" y="181" width="170" height="28" rx="4" fill="#dcfce7"/>
  <text x="335" y="199" font-family="system-ui,sans-serif" font-size="10" font-weight="600" fill="#14532d">Mejor conversión ventas</text>
  <text x="487" y="199" text-anchor="end" font-family="system-ui,sans-serif" font-size="11" font-weight="800" fill="#14532d">$2,4M</text>

  <line x1="325" y1="223" x2="495" y2="223" stroke="#16a34a" stroke-width="1.5"/>
  <text x="335" y="243" font-family="system-ui,sans-serif" font-size="11" font-weight="700" fill="#064e3b">Total ahorro/año</text>
  <text x="487" y="243" text-anchor="end" font-family="system-ui,sans-serif" font-size="14" font-weight="800" fill="#16a34a">$7,8M</text>
  <text x="410" y="262" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#6b7280">año tras año, recurrente</text>

  <!-- Right side: ROI box -->
  <rect x="540" y="70" width="220" height="200" rx="12" fill="#064e3b"/>
  <text x="650" y="100" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" font-weight="700" fill="#a7f3d0" letter-spacing="1">ROI AÑO 1</text>
  <text x="650" y="160" text-anchor="middle" font-family="system-ui,sans-serif" font-size="56" font-weight="800" fill="#fff" letter-spacing="-2">2,4x</text>
  <text x="650" y="184" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#a7f3d0">sobre copago real</text>

  <line x1="570" y1="200" x2="730" y2="200" stroke="#10b981" stroke-width="1" stroke-opacity="0.4"/>

  <text x="650" y="222" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#a7f3d0">Payback:</text>
  <text x="650" y="245" text-anchor="middle" font-family="system-ui,sans-serif" font-size="20" font-weight="700" fill="#fff">5 meses</text>
  <text x="650" y="260" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#a7f3d0">desde puesta en marcha</text>

  <!-- Bottom note -->
  <text x="400" y="298" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" font-style="italic" fill="#6b7280">Ejemplo basado en pyme tipo: 50-80 ha o servicios con 20-50 personas. Cifras conservadoras.</text>
</svg>
