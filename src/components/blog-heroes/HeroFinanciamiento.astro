---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Diagrama de flujo de financiamiento CORFO FIA SERCOTEC">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>

  <!-- Source box 1: CORFO -->
  <g transform="translate(200, 50)">
    <rect x="-65" y="-25" width="130" height="50" rx="8" fill="#047857"/>
    <text y="5" text-anchor="middle" font-family="system-ui,sans-serif" font-size="16" font-weight="700" fill="#ffffff">CORFO</text>
  </g>

  <!-- Source box 2: FIA -->
  <g transform="translate(400, 50)">
    <rect x="-65" y="-25" width="130" height="50" rx="8" fill="#059669"/>
    <text y="5" text-anchor="middle" font-family="system-ui,sans-serif" font-size="16" font-weight="700" fill="#ffffff">FIA</text>
  </g>

  <!-- Source box 3: SERCOTEC -->
  <g transform="translate(600, 50)">
    <rect x="-65" y="-25" width="130" height="50" rx="8" fill="#10b981"/>
    <text y="5" text-anchor="middle" font-family="system-ui,sans-serif" font-size="16" font-weight="700" fill="#ffffff">SERCOTEC</text>
  </g>

  <!-- Arrows from sources to central box -->
  <!-- Arrow from CORFO -->
  <line x1="200" y1="75" x2="340" y2="145" stroke="#047857" stroke-width="2.5" marker-end="url(#arrowGreen)"/>
  <rect x="220" y="100" width="60" height="20" rx="4" fill="#ffffff" stroke="#047857" stroke-width="1"/>
  <text x="250" y="114" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" font-weight="700" fill="#047857">50-60%</text>

  <!-- Arrow from FIA -->
  <line x1="400" y1="75" x2="400" y2="145" stroke="#059669" stroke-width="2.5" marker-end="url(#arrowGreen)"/>
  <rect x="410" y="98" width="45" height="20" rx="4" fill="#ffffff" stroke="#059669" stroke-width="1"/>
  <text x="432" y="112" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" font-weight="700" fill="#059669">80%</text>

  <!-- Arrow from SERCOTEC -->
  <line x1="600" y1="75" x2="460" y2="145" stroke="#10b981" stroke-width="2.5" marker-end="url(#arrowGreen)"/>
  <rect x="500" y="100" width="45" height="20" rx="4" fill="#ffffff" stroke="#10b981" stroke-width="1"/>
  <text x="522" y="114" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" font-weight="700" fill="#10b981">98%</text>

  <!-- Central box: Tu Proyecto -->
  <g transform="translate(400, 170)">
    <rect x="-80" y="-25" width="160" height="50" rx="10" fill="#1f2937" stroke="#047857" stroke-width="2"/>
    <text y="5" text-anchor="middle" font-family="system-ui,sans-serif" font-size="15" font-weight="700" fill="#ffffff">Tu Proyecto</text>
  </g>

  <!-- Arrow down to laptop -->
  <line x1="400" y1="195" x2="400" y2="215" stroke="#1f2937" stroke-width="2"/>

  <!-- Laptop icon -->
  <g transform="translate(400, 235)">
    <!-- Screen -->
    <rect x="-30" y="-15" width="60" height="20" rx="3" fill="#1f2937"/>
    <rect x="-26" y="-12" width="52" height="14" rx="1" fill="#d1fae5"/>
    <!-- Small app icon on screen -->
    <rect x="-8" y="-8" width="16" height="8" rx="1" fill="#059669"/>
    <!-- Base -->
    <path d="M-38,5 L38,5 L32,10 L-32,10 Z" fill="#1f2937"/>
  </g>

  <!-- Arrow marker -->
  <defs>
    <marker id="arrowGreen" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
      <path d="M0,0 L8,4 L0,8 Z" fill="#047857"/>
    </marker>
  </defs>
</svg>
