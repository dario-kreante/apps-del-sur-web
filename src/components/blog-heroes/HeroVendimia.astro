---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Grafico de costos de vendimia por mes con trabajadores">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>

  <!-- Chart area -->
  <!-- Y axis -->
  <line x1="160" y1="40" x2="160" y2="195" stroke="#a7f3d0" stroke-width="1.5"/>
  <!-- X axis -->
  <line x1="160" y1="195" x2="640" y2="195" stroke="#a7f3d0" stroke-width="1.5"/>

  <!-- Y axis labels -->
  <text x="150" y="195" text-anchor="end" font-family="system-ui,sans-serif" font-size="9" fill="#6ee7b7">$0</text>
  <text x="150" y="145" text-anchor="end" font-family="system-ui,sans-serif" font-size="9" fill="#6ee7b7">$70K</text>
  <text x="150" y="95" text-anchor="end" font-family="system-ui,sans-serif" font-size="9" fill="#6ee7b7">$142K</text>

  <!-- Grid lines -->
  <line x1="160" y1="145" x2="640" y2="145" stroke="#d1fae5" stroke-width="0.8" stroke-dasharray="4,4"/>
  <line x1="160" y1="95" x2="640" y2="95" stroke="#d1fae5" stroke-width="0.8" stroke-dasharray="4,4"/>

  <!-- Bar 1: Mar (tallest) -->
  <rect x="220" y="55" width="70" height="140" rx="4" fill="#047857"/>
  <text x="255" y="215" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="600" fill="#1f2937">Mar</text>

  <!-- Bar 2: Abr -->
  <rect x="330" y="95" width="70" height="100" rx="4" fill="#059669"/>
  <text x="365" y="215" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="600" fill="#1f2937">Abr</text>

  <!-- Bar 3: May -->
  <rect x="440" y="130" width="70" height="65" rx="4" fill="#10b981"/>
  <text x="475" y="215" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="600" fill="#1f2937">May</text>

  <!-- Bar 4: Jun -->
  <rect x="550" y="155" width="70" height="40" rx="4" fill="#34d399"/>
  <text x="585" y="215" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="600" fill="#1f2937">Jun</text>

  <!-- Cost label on tallest bar -->
  <rect x="215" y="38" width="80" height="18" rx="4" fill="#1f2937"/>
  <text x="255" y="51" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" font-weight="700" fill="#ffffff">$142K/ha</text>

  <!-- Worker silhouettes below chart -->
  <g transform="translate(240, 240)">
    <circle r="5" fill="#6ee7b7"/>
    <rect x="-4" y="5" width="8" height="10" rx="2" fill="#6ee7b7"/>
  </g>
  <g transform="translate(258, 240)">
    <circle r="5" fill="#6ee7b7"/>
    <rect x="-4" y="5" width="8" height="10" rx="2" fill="#6ee7b7"/>
  </g>
  <g transform="translate(276, 240)">
    <circle r="5" fill="#a7f3d0"/>
    <rect x="-4" y="5" width="8" height="10" rx="2" fill="#a7f3d0"/>
  </g>
  <g transform="translate(350, 240)">
    <circle r="5" fill="#6ee7b7"/>
    <rect x="-4" y="5" width="8" height="10" rx="2" fill="#6ee7b7"/>
  </g>
  <g transform="translate(368, 240)">
    <circle r="5" fill="#a7f3d0"/>
    <rect x="-4" y="5" width="8" height="10" rx="2" fill="#a7f3d0"/>
  </g>
  <g transform="translate(475, 240)">
    <circle r="5" fill="#a7f3d0"/>
    <rect x="-4" y="5" width="8" height="10" rx="2" fill="#a7f3d0"/>
  </g>
</svg>
