---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Comparativa de costos de sistemas de gestión para viñas chilenas">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>

  <!-- Title -->
  <text x="400" y="28" text-anchor="middle" font-family="system-ui,sans-serif" font-size="13" font-weight="700" fill="#1f2937">Gestión Vitivinícola — Comparativa de Costos</text>

  <!-- Three columns: Genérico vs Especializado vs A Medida -->
  <!-- Column 1: Genérico -->
  <rect x="40" y="48" width="220" height="180" rx="10" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
  <rect x="40" y="48" width="220" height="36" rx="10" fill="#6b7280"/>
  <rect x="40" y="74" width="220" height="10" fill="#6b7280"/>
  <text x="150" y="72" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="700" fill="#ffffff">Software Genérico</text>

  <!-- Grape icon -->
  <circle cx="150" cy="104" r="5" fill="#9ca3af"/>
  <circle cx="142" cy="112" r="5" fill="#9ca3af"/>
  <circle cx="158" cy="112" r="5" fill="#9ca3af"/>

  <text x="150" y="138" text-anchor="middle" font-family="system-ui,sans-serif" font-size="16" font-weight="800" fill="#6b7280">1–5 UF/mes</text>
  <text x="150" y="156" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">Suscripción mensual</text>
  <line x1="70" y1="166" x2="230" y2="166" stroke="#e5e7eb" stroke-width="1"/>
  <text x="150" y="182" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#9ca3af">No adaptado a viñas</text>
  <text x="150" y="196" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#9ca3af">Sin cuarteles/labores</text>
  <text x="150" y="210" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#9ca3af">Funciones limitadas</text>

  <!-- Column 2: Especializado (highlighted) -->
  <rect x="290" y="48" width="220" height="180" rx="10" fill="#ffffff" stroke="#047857" stroke-width="2.5"/>
  <rect x="290" y="48" width="220" height="36" rx="10" fill="#047857"/>
  <rect x="290" y="74" width="220" height="10" fill="#047857"/>
  <text x="400" y="72" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="700" fill="#ffffff">Especializado Viñas</text>

  <!-- Grape icon colored -->
  <circle cx="400" cy="104" r="5" fill="#047857"/>
  <circle cx="392" cy="112" r="5" fill="#059669"/>
  <circle cx="408" cy="112" r="5" fill="#059669"/>

  <text x="400" y="138" text-anchor="middle" font-family="system-ui,sans-serif" font-size="16" font-weight="800" fill="#047857">5–25 UF/mes</text>
  <text x="400" y="156" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">Suscripción o licencia</text>
  <line x1="320" y1="166" x2="480" y2="166" stroke="#e5e7eb" stroke-width="1"/>
  <text x="400" y="182" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#047857" font-weight="600">Cuarteles y labores</text>
  <text x="400" y="196" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#047857" font-weight="600">Gestión temporeros</text>
  <text x="400" y="210" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#047857" font-weight="600">Trazabilidad incluida</text>

  <!-- Best value badge -->
  <rect x="365" y="38" width="70" height="16" rx="8" fill="#047857"/>
  <text x="400" y="49" text-anchor="middle" font-family="system-ui,sans-serif" font-size="8" font-weight="700" fill="#ffffff">MEJOR VALOR</text>

  <!-- Column 3: A Medida -->
  <rect x="540" y="48" width="220" height="180" rx="10" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
  <rect x="540" y="48" width="220" height="36" rx="10" fill="#10b981"/>
  <rect x="540" y="74" width="220" height="10" fill="#10b981"/>
  <text x="650" y="72" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="700" fill="#ffffff">Desarrollo a Medida</text>

  <!-- Custom icon -->
  <rect x="636" y="98" width="28" height="20" rx="4" fill="#10b981" opacity="0.3"/>
  <rect x="640" y="102" width="20" height="12" rx="2" fill="#10b981"/>

  <text x="650" y="138" text-anchor="middle" font-family="system-ui,sans-serif" font-size="16" font-weight="800" fill="#10b981">500–3.000 UF</text>
  <text x="650" y="156" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">Inversión única + mantención</text>
  <line x1="570" y1="166" x2="730" y2="166" stroke="#e5e7eb" stroke-width="1"/>
  <text x="650" y="182" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">100% personalizado</text>
  <text x="650" y="196" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">Propiedad del código</text>
  <text x="650" y="210" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">Mayor tiempo desarrollo</text>

  <!-- Footer -->
  <text x="400" y="250" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#9ca3af">* Rangos referenciales. El costo real depende de hectáreas, cuarteles y funcionalidades requeridas.</text>
</svg>
