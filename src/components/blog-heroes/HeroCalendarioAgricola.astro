---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Calendario agricola con actividades estacionales">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>
  <!-- Horizontal timeline -->
  <line x1="100" y1="140" x2="700" y2="140" stroke="#a7f3d0" stroke-width="3" stroke-linecap="round"/>

  <!-- Marker 1: Vendimia (Mar) - grape cluster -->
  <g transform="translate(180, 140)">
    <circle r="28" fill="#d1fae5" stroke="#059669" stroke-width="2"/>
    <!-- Grape cluster -->
    <circle cx="-5" cy="-6" r="4" fill="#047857"/>
    <circle cx="5" cy="-6" r="4" fill="#047857"/>
    <circle cx="0" cy="-1" r="4" fill="#059669"/>
    <circle cx="-5" cy="4" r="4" fill="#059669"/>
    <circle cx="5" cy="4" r="4" fill="#059669"/>
    <circle cx="0" cy="9" r="4" fill="#10b981"/>
    <line x1="0" y1="-14" x2="0" y2="-10" stroke="#047857" stroke-width="1.5"/>
    <text y="48" text-anchor="middle" font-family="system-ui,sans-serif" font-size="13" font-weight="700" fill="#047857">Vendimia</text>
    <text y="64" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" fill="#059669">Mar</text>
  </g>

  <!-- Marker 2: Poda (Jun) - scissors -->
  <g transform="translate(340, 140)">
    <circle r="28" fill="#d1fae5" stroke="#059669" stroke-width="2"/>
    <!-- Scissors icon -->
    <circle cx="-6" cy="6" r="5" fill="none" stroke="#047857" stroke-width="1.8"/>
    <circle cx="6" cy="6" r="5" fill="none" stroke="#047857" stroke-width="1.8"/>
    <line x1="-3" y1="2" x2="5" y2="-10" stroke="#047857" stroke-width="2" stroke-linecap="round"/>
    <line x1="3" y1="2" x2="-5" y2="-10" stroke="#047857" stroke-width="2" stroke-linecap="round"/>
    <text y="48" text-anchor="middle" font-family="system-ui,sans-serif" font-size="13" font-weight="700" fill="#047857">Poda</text>
    <text y="64" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" fill="#059669">Jun</text>
  </g>

  <!-- Marker 3: Desbrote (Sep) - leaf -->
  <g transform="translate(500, 140)">
    <circle r="28" fill="#d1fae5" stroke="#059669" stroke-width="2"/>
    <!-- Leaf icon -->
    <path d="M0,-12 C12,-10 14,2 10,10 C6,6 0,8 -4,10 C-2,4 -10,-6 0,-12Z" fill="#059669"/>
    <path d="M0,-8 C2,-2 4,2 6,6" fill="none" stroke="#d1fae5" stroke-width="1.2"/>
    <text y="48" text-anchor="middle" font-family="system-ui,sans-serif" font-size="13" font-weight="700" fill="#047857">Desbrote</text>
    <text y="64" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" fill="#059669">Sep</text>
  </g>

  <!-- Marker 4: Riego (Nov) - water drops -->
  <g transform="translate(660, 140)">
    <circle r="28" fill="#d1fae5" stroke="#059669" stroke-width="2"/>
    <!-- Water drops -->
    <path d="M0,-12 C-6,-4 -8,2 -5,7 C-2,11 2,11 5,7 C8,2 6,-4 0,-12Z" fill="#10b981"/>
    <ellipse cx="0" cy="4" rx="3" ry="2" fill="#6ee7b7" opacity="0.5"/>
    <text y="48" text-anchor="middle" font-family="system-ui,sans-serif" font-size="13" font-weight="700" fill="#047857">Riego</text>
    <text y="64" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" fill="#059669">Nov</text>
  </g>

  <!-- Timeline dots -->
  <circle cx="180" cy="140" r="5" fill="#047857"/>
  <circle cx="340" cy="140" r="5" fill="#047857"/>
  <circle cx="500" cy="140" r="5" fill="#047857"/>
  <circle cx="660" cy="140" r="5" fill="#047857"/>

  <!-- Title area -->
  <text x="400" y="40" text-anchor="middle" font-family="system-ui,sans-serif" font-size="14" font-weight="600" fill="#1f2937" opacity="0.5">Ciclo Productivo Anual</text>
</svg>
