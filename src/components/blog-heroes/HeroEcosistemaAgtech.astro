---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Ecosistema agtech en la region del Maule con actores conectados">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>

  <!-- Simplified Maule region outline (elongated vertical shape) -->
  <path d="M370,30 C390,28 410,35 420,50 C430,70 425,100 430,130 C435,160 428,185 420,210 C412,230 395,240 380,238 C365,236 355,225 350,210 C345,190 340,160 345,130 C348,100 352,70 358,50 C362,38 365,32 370,30Z" fill="#d1fae5" stroke="#10b981" stroke-width="2"/>

  <!-- Network dotted lines -->
  <line x1="375" y1="65" x2="180" y2="55" stroke="#a7f3d0" stroke-width="1.5" stroke-dasharray="4,4"/>
  <line x1="400" y1="100" x2="600" y2="70" stroke="#a7f3d0" stroke-width="1.5" stroke-dasharray="4,4"/>
  <line x1="380" y1="145" x2="170" y2="160" stroke="#a7f3d0" stroke-width="1.5" stroke-dasharray="4,4"/>
  <line x1="395" y1="180" x2="620" y2="170" stroke="#a7f3d0" stroke-width="1.5" stroke-dasharray="4,4"/>
  <line x1="375" y1="210" x2="550" y2="230" stroke="#a7f3d0" stroke-width="1.5" stroke-dasharray="4,4"/>

  <!-- Pin 1: Thinkagro (top-left) -->
  <g transform="translate(160, 45)">
    <path d="M0,-18 C8,-18 14,-12 14,-5 C14,4 0,16 0,16 C0,16 -14,4 -14,-5 C-14,-12 -8,-18 0,-18Z" fill="#047857"/>
    <circle cy="-6" r="4" fill="#d1fae5"/>
    <text y="26" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" font-weight="600" fill="#1f2937">Thinkagro</text>
  </g>

  <!-- Pin 2: INIA (top-right) -->
  <g transform="translate(620, 58)">
    <path d="M0,-22 C10,-22 18,-14 18,-6 C18,5 0,20 0,20 C0,20 -18,5 -18,-6 C-18,-14 -10,-22 0,-22Z" fill="#059669"/>
    <circle cy="-7" r="5" fill="#d1fae5"/>
    <text y="32" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" font-weight="600" fill="#1f2937">INIA</text>
  </g>

  <!-- Pin 3: CORFO (center-left) -->
  <g transform="translate(150, 155)">
    <path d="M0,-20 C9,-20 16,-13 16,-5.5 C16,5 0,18 0,18 C0,18 -16,5 -16,-5.5 C-16,-13 -9,-20 0,-20Z" fill="#10b981"/>
    <circle cy="-6.5" r="4.5" fill="#d1fae5"/>
    <text y="28" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" font-weight="600" fill="#1f2937">CORFO</text>
  </g>

  <!-- Pin 4: UTalca (center-right) -->
  <g transform="translate(640, 162)">
    <path d="M0,-16 C7,-16 12,-11 12,-5 C12,3 0,14 0,14 C0,14 -12,3 -12,-5 C-12,-11 -7,-16 0,-16Z" fill="#34d399"/>
    <circle cy="-5.5" r="3.5" fill="#d1fae5"/>
    <text y="24" text-anchor="middle" font-family="system-ui,sans-serif" font-size="11" font-weight="600" fill="#1f2937">UTalca</text>
  </g>

  <!-- Pin 5: Apps del Sur (bottom, highlighted) -->
  <g transform="translate(560, 222)">
    <path d="M0,-24 C11,-24 20,-16 20,-7 C20,6 0,22 0,22 C0,22 -20,6 -20,-7 C-20,-16 -11,-24 0,-24Z" fill="#047857" stroke="#1f2937" stroke-width="1.5"/>
    <circle cy="-8" r="6" fill="#d1fae5"/>
    <text y="34" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="700" fill="#047857">Apps del Sur</text>
  </g>

  <!-- Decorative network nodes on map -->
  <circle cx="375" cy="65" r="3" fill="#047857"/>
  <circle cx="400" cy="100" r="3" fill="#059669"/>
  <circle cx="380" cy="145" r="3" fill="#10b981"/>
  <circle cx="395" cy="180" r="3" fill="#34d399"/>
  <circle cx="375" cy="210" r="3" fill="#047857"/>
</svg>
