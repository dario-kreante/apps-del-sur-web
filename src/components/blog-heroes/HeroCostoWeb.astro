---
const { class: className } = Astro.props;
---
<svg viewBox="0 0 800 260" xmlns="http://www.w3.org/2000/svg" class={className} role="img" aria-label="Rangos de inversión en sitios web profesionales en Chile">
  <rect width="800" height="260" rx="12" fill="#ecfdf5"/>

  <!-- Title -->
  <text x="400" y="28" text-anchor="middle" font-family="system-ui,sans-serif" font-size="13" font-weight="700" fill="#1f2937">Inversión en Web Profesional</text>

  <!-- Three monitor-like cards -->
  <!-- Landing Page -->
  <rect x="40" y="48" width="220" height="175" rx="10" fill="#ffffff" stroke="#a7f3d0" stroke-width="1.5"/>
  <!-- Monitor screen area -->
  <rect x="55" y="58" width="190" height="80" rx="6" fill="#f0fdf4"/>
  <!-- Simple wireframe inside monitor -->
  <rect x="70" y="68" width="80" height="10" rx="2" fill="#a7f3d0"/>
  <rect x="70" y="84" width="160" height="6" rx="2" fill="#d1fae5"/>
  <rect x="70" y="96" width="140" height="6" rx="2" fill="#d1fae5"/>
  <rect x="70" y="112" width="60" height="16" rx="4" fill="#047857"/>
  <text x="100" y="124" text-anchor="middle" font-family="system-ui,sans-serif" font-size="8" font-weight="600" fill="#ffffff">CTA</text>
  <!-- Monitor stand -->
  <rect x="135" y="138" width="30" height="8" rx="2" fill="#e5e7eb"/>
  <rect x="120" y="146" width="60" height="4" rx="2" fill="#e5e7eb"/>

  <text x="150" y="170" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="700" fill="#047857">Landing Page</text>
  <text x="150" y="186" text-anchor="middle" font-family="system-ui,sans-serif" font-size="18" font-weight="800" fill="#047857">30–100 UF</text>
  <text x="150" y="202" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">1-2 semanas</text>
  <text x="150" y="216" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">1-3 páginas</text>

  <!-- Sitio Corporativo -->
  <rect x="290" y="48" width="220" height="175" rx="10" fill="#ffffff" stroke="#059669" stroke-width="2"/>
  <rect x="305" y="58" width="190" height="80" rx="6" fill="#f0fdf4"/>
  <!-- Multi-page wireframe -->
  <rect x="320" y="68" width="80" height="10" rx="2" fill="#a7f3d0"/>
  <rect x="320" y="84" width="40" height="6" rx="2" fill="#d1fae5"/>
  <rect x="365" y="84" width="40" height="6" rx="2" fill="#d1fae5"/>
  <rect x="410" y="84" width="40" height="6" rx="2" fill="#d1fae5"/>
  <rect x="320" y="96" width="70" height="30" rx="4" fill="#d1fae5"/>
  <rect x="396" y="96" width="70" height="30" rx="4" fill="#d1fae5"/>
  <rect x="385" y="138" width="30" height="8" rx="2" fill="#e5e7eb"/>
  <rect x="370" y="146" width="60" height="4" rx="2" fill="#e5e7eb"/>

  <text x="400" y="170" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="700" fill="#059669">Sitio Corporativo</text>
  <text x="400" y="186" text-anchor="middle" font-family="system-ui,sans-serif" font-size="18" font-weight="800" fill="#059669">100–400 UF</text>
  <text x="400" y="202" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">3-6 semanas</text>
  <text x="400" y="216" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">5-15 páginas + CMS</text>

  <!-- E-commerce -->
  <rect x="540" y="48" width="220" height="175" rx="10" fill="#ffffff" stroke="#10b981" stroke-width="1.5"/>
  <rect x="555" y="58" width="190" height="80" rx="6" fill="#f0fdf4"/>
  <!-- E-commerce wireframe -->
  <rect x="570" y="68" width="80" height="10" rx="2" fill="#a7f3d0"/>
  <rect x="570" y="84" width="50" height="40" rx="4" fill="#d1fae5"/>
  <rect x="626" y="84" width="50" height="40" rx="4" fill="#d1fae5"/>
  <rect x="682" y="84" width="50" height="40" rx="4" fill="#d1fae5"/>
  <!-- Cart icon -->
  <circle cx="720" cy="72" r="8" fill="#10b981"/>
  <text x="720" y="76" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#ffffff">🛒</text>
  <rect x="635" y="138" width="30" height="8" rx="2" fill="#e5e7eb"/>
  <rect x="620" y="146" width="60" height="4" rx="2" fill="#e5e7eb"/>

  <text x="650" y="170" text-anchor="middle" font-family="system-ui,sans-serif" font-size="12" font-weight="700" fill="#10b981">E-commerce</text>
  <text x="650" y="186" text-anchor="middle" font-family="system-ui,sans-serif" font-size="18" font-weight="800" fill="#10b981">300–1.500 UF</text>
  <text x="650" y="202" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">2-4 meses</text>
  <text x="650" y="216" text-anchor="middle" font-family="system-ui,sans-serif" font-size="10" fill="#6b7280">Catálogo + pagos</text>

  <!-- Footer -->
  <text x="400" y="250" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" fill="#9ca3af">* Rangos referenciales en UF (1 UF ≈ $38.000 CLP). Incluye diseño, desarrollo y puesta en marcha.</text>
</svg>
