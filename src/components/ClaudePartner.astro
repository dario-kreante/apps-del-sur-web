---
import { claudePartner } from '../data/content';
import Badge from './ui/Badge.astro';
import Button from './ui/Button.astro';
import Sparkle from './icons/Sparkle.astro';
import Check from './icons/Check.astro';
import ArrowRight from './icons/ArrowRight.astro';
---

<section class="py-24 bg-gray-50">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">
      <!-- Left: Icon block -->
      <div class="md:w-2/5 flex justify-center">
        <div class="relative">
          <div class="w-48 h-48 md:w-56 md:h-56 rounded-3xl bg-emerald-700 flex items-center justify-center shadow-xl shadow-emerald-700/20">
            <Sparkle class="w-20 h-20 md:w-24 md:h-24 text-white" />
          </div>
          <!-- Decorative circles -->
          <div class="absolute -top-4 -right-4 w-16 h-16 bg-emerald-100 rounded-full -z-10"></div>
          <div class="absolute -bottom-6 -left-6 w-24 h-24 bg-emerald-50 rounded-full -z-10"></div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="md:w-3/5">
        <Badge class="mb-4">
          <Sparkle class="w-4 h-4" />
          <span>{claudePartner.badge}</span>
        </Badge>

        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-4">
          {claudePartner.title}
        </h2>

        <p class="text-gray-500 text-lg mb-6">
          {claudePartner.description}
        </p>

        <ul class="space-y-3 mb-8">
          {claudePartner.bullets.map((bullet) => (
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center shrink-0 mt-0.5">
                <Check class="w-3 h-3" />
              </div>
              <span class="text-gray-600">{bullet}</span>
            </li>
          ))}
        </ul>

        <Button href={claudePartner.ctaHref} variant="outline" size="lg">
          {claudePartner.cta}
          <ArrowRight class="w-5 h-5" />
        </Button>
      </div>
    </div>
  </div>
</section>
