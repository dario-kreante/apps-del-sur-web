---
const whatsappUrl = 'https://wa.me/56945262335?text=Hola%2C%20me%20interesa%20saber%20m%C3%A1s%20sobre%20Apps%20del%20Sur';
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
  id="whatsapp-float"
  class="whatsapp-float"
>
  <svg viewBox="0 0 32 32" width="28" height="28" fill="currentColor" aria-hidden="true">
    <path d="M16.004 0h-.008C7.174 0 0 7.176 0 16c0 3.5 1.128 6.744 3.046 9.378L1.054 31.29l6.118-1.958A15.91 15.91 0 0 0 16.004 32C24.826 32 32 24.822 32 16S24.826 0 16.004 0zm9.335 22.594c-.39 1.1-1.932 2.014-3.164 2.28-.844.18-1.946.322-5.66-1.216-4.752-1.968-7.806-6.782-8.04-7.098-.226-.316-1.9-2.53-1.9-4.826s1.202-3.424 1.63-3.892c.428-.468.934-.586 1.246-.586.312 0 .624.004.896.016.288.014.674-.11 1.054.804.39.938 1.326 3.234 1.444 3.468.116.234.196.508.04.816-.156.312-.234.506-.468.78-.234.274-.492.612-.702.822-.234.234-.478.49-.206.96.274.468 1.216 2.006 2.61 3.25 1.792 1.6 3.302 2.096 3.77 2.33.468.234.742.196 1.016-.118.274-.312 1.17-1.364 1.484-1.832.312-.468.624-.39 1.054-.234.428.156 2.724 1.286 3.192 1.52.468.234.78.352.896.546.116.196.116 1.12-.274 2.216z"/>
  </svg>
</a>

<style>
  .whatsapp-float {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 9999px;
    background-color: #25D366;
    color: white;
    box-shadow: 0 4px 14px rgba(37, 211, 102, 0.4);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    animation: whatsapp-pulse 3s ease-in-out infinite;
  }

  .whatsapp-float:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
  }

  .whatsapp-float:active {
    transform: scale(0.95);
  }

  @keyframes whatsapp-pulse {
    0%, 100% {
      box-shadow: 0 4px 14px rgba(37, 211, 102, 0.4);
    }
    50% {
      box-shadow: 0 4px 20px rgba(37, 211, 102, 0.6), 0 0 0 8px rgba(37, 211, 102, 0.1);
    }
  }

  /* En mobile más pequeño y más pegado al borde */
  @media (max-width: 640px) {
    .whatsapp-float {
      bottom: 1rem;
      right: 1rem;
      width: 3rem;
      height: 3rem;
    }

    .whatsapp-float svg {
      width: 24px;
      height: 24px;
    }
  }
</style>

<script is:inline>
  document.getElementById('whatsapp-float')?.addEventListener('click', function() {
    if (typeof window.dataLayer !== 'undefined') {
      window.dataLayer.push({
        event: 'whatsapp_click',
        event_category: 'contacto',
        event_label: 'boton_flotante',
        value: 1
      });
    }
  });
</script>
