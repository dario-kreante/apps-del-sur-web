---
import { aiTrainingCallout } from '../data/content';
import Sparkle from './icons/Sparkle.astro';
import ArrowRight from './icons/ArrowRight.astro';
---

<section class="py-12 bg-emerald-700">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
      <!-- Icon -->
      <div class="w-14 h-14 rounded-2xl bg-white/15 flex items-center justify-center shrink-0">
        <Sparkle class="w-7 h-7 text-white" />
      </div>

      <!-- Content -->
      <div class="flex-1 text-center md:text-left">
        <p class="text-emerald-200 text-xs font-semibold uppercase tracking-widest mb-1">
          {aiTrainingCallout.headline}
        </p>
        <h3 class="text-white text-xl md:text-2xl font-bold mb-2">
          {aiTrainingCallout.title}
        </h3>
        <p class="text-emerald-100 text-sm leading-relaxed max-w-2xl">
          {aiTrainingCallout.description}
        </p>
      </div>

      <!-- CTA -->
      <a
        href={aiTrainingCallout.ctaHref}
        class="inline-flex items-center gap-2 bg-white text-emerald-800 font-semibold text-[15px] h-12 px-6 rounded-lg hover:bg-emerald-50 transition-colors shrink-0"
      >
        {aiTrainingCallout.cta}
        <ArrowRight class="w-5 h-5" />
      </a>
    </div>
  </div>
</section>
