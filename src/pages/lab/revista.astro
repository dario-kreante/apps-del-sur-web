  <script is:inline>
    // Wait for fonts + StPageFlip before initializing
    document.fonts.ready.then(() => {
      initFlipbook();
    });

    function initFlipbook() {
      const host = document.getElementById('flipbook');
      const isMobile = window.innerWidth < 800;
      const w = isMobile ? Math.min(window.innerWidth - 24, 380) : 550;
      const h = Math.round(w * 1.4);

      const pageFlip = new St.PageFlip(host, {
        width: w,
        height: h,
        size: 'fixed',
        minWidth: 280,
        maxWidth: 700,
        minHeight: 380,
        maxHeight: 980,
        showCover: true,
        flippingTime: 700,
        usePortrait: isMobile,
        startZIndex: 0,
        autoSize: false,
        maxShadowOpacity: 0.5,
        mobileScrollSupport: true,
        useMouseEvents: true,
        swipeDistance: 30,
        drawShadow: true,
        clickEventForward: true,
      });

      const pages = host.querySelectorAll('.page');
      pageFlip.loadFromHTML(pages);

      document.getElementById('loading')?.remove();

      // Controls
      document.getElementById('prev')?.addEventListener('click', () => pageFlip.flipPrev());
      document.getElementById('next')?.addEventListener('click', () => pageFlip.flipNext());
      document.getElementById('zoom')?.addEventListener('click', () => {
        const stage = document.querySelector('.stage');
        if (stage.style.transform === 'scale(1.18)') {
          stage.style.transform = 'scale(1)';
        } else {
          stage.style.transformOrigin = 'top center';
          stage.style.transform = 'scale(1.18)';
        }
      });

      // Keyboard nav
      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') pageFlip.flipNext();
        if (e.key === 'ArrowLeft') pageFlip.flipPrev();
      });
    }
  </script>
