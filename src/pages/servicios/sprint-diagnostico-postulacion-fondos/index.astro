---
import ServicePage from '../../../layouts/ServicePage.astro';

const service = {
  slug: 'sprint-diagnostico-postulacion-fondos',
  badge: 'Consultoría con success-fee',
  title: 'Sprint Diagnóstico + Postulación a Fondo',
  subtitle: 'En 4 a 6 semanas tienes el plan, el business case y el formulario listo para postular.',
  metaTitle: 'Sprint de Diagnóstico + Postulación a Fondos CORFO, FIA y SERCOTEC | Apps del Sur',
  metaDescription: 'Consultoría especializada en transformación digital de pymes chilenas con foco en fondos concursables: CORFO Digitalización, FIA Interés Privado, SERCOTEC CRECE y Kit Digital. 4-6 semanas, business case en CLP, postulación entregada al fondo, parte success-based.',
