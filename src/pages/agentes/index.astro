---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import ContactForm from '../../components/ContactForm.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import ArrowRight from '../../components/icons/ArrowRight.astro';
import Sparkle from '../../components/icons/Sparkle.astro';
import Check from '../../components/icons/Check.astro';
import MadurezIACallout from '../../components/agentes/MadurezIACallout.astro';
import { agentPages, agentRoadmap } from '../../data/agentes';
import { sectorPages } from '../../data/sectores';
import { getCollection } from 'astro:content';

const agentes = Object.values(agentPages);
const sectores = Object.values(sectorPages);

const allPosts = await getCollection('blog');
const postsBySlug = new Map(allPosts.map((p) => [p.id, p]));

const title = 'Agentes de IA por WhatsApp para Pymes Chile · Por función y por sector | Apps del Sur';
const description =
  'Agentes de IA para pymes chilenas, por función (agendamiento, WhatsApp, SDR, retención, compliance) y por sector (viñas, clínicas, hoteles, abogados, inmobiliarias, constructoras, clubes deportivos, funerarias). Implementación 2-6 semanas. Financiable con CORFO, SERCOTEC y FIA.';
const keywords =
  'agentes IA Chile, IA WhatsApp pyme, agente IA por sector, software clínica dental Chile, software hoteles Chile, software constructora Chile, agente IA inmobiliaria, automatización pyme';

const allItems = [...agentes, ...sectores];

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Catálogo de Agentes IA — Apps del Sur',
  description,
  itemListElement: allItems.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Service',
      name: a.name,
      url: `https://appsdelsur.cl${a.url}`,
      description: a.shortDescription,
    },
  })),
});
---

<Layout
  title={title}
  description={description}
  canonical="https://appsdelsur.cl/agentes/"
  keywords={keywords}
  ogTitle="Agentes de IA por WhatsApp para Pymes Chile"
  ogDescription={description}
>
  <script type="application/ld+json" set:html={jsonLd} />

  <Header />

  <main id="main-content" class="pt-24">
    <!-- Breadcrumb -->
    <div class="max-w-[1200px] mx-auto px-6 mb-6">
      <nav class="text-sm text-gray-500" aria-label="Breadcrumb">
        <a href="/" class="text-emerald-600 hover:text-emerald-700 transition-colors">Inicio</a>
        <span class="mx-2">/</span>
        <span class="text-gray-400">Agentes IA</span>
      </nav>
    </div>

    <!-- Hero -->
    <section class="pt-4 pb-16">
      <div class="max-w-[1100px] mx-auto px-6 text-center">
        <Badge class="mb-5">🟢 WhatsApp · IA · Pymes Chile</Badge>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 tracking-tight leading-[1.05] mb-6">
          Agentes de IA que
          <span class="text-emerald-700">trabajan por WhatsApp</span>
          <br class="hidden md:block" />
          mientras usted duerme
        </h1>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed max-w-[760px] mx-auto mb-8">
          98% de apertura. Respuesta en segundos. Sin contratar más gente. Cada agente está diseñado para un dolor concreto de una vertical específica — no son "chatbots genéricos".
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <Button href="#sectores" size="lg">
            Ver por sector ({sectores.length} verticales)
            <ArrowRight class="w-5 h-5" />
          </Button>
          <Button href="#verticales" variant="outline" size="lg">
            Ver por función ({agentes.length} agentes)
          </Button>
        </div>
        <div class="mt-4 text-center">
          <a href="/diagnostico-madurez-ia/?source=agentes-hub" class="text-sm text-emerald-700 hover:text-emerald-800 font-medium">
            O diagnostique su madurez IA (gratis · 6 min) →
          </a>
        </div>
        <div class="mt-10 grid grid-cols-3 max-w-[640px] mx-auto gap-4 text-center">
          <div>
            <div class="text-3xl font-bold text-emerald-700">98%</div>
            <div class="text-xs text-gray-500 mt-1">Apertura WhatsApp Chile</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-emerald-700">&lt;30s</div>
            <div class="text-xs text-gray-500 mt-1">Tiempo de respuesta</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-emerald-700">2-6 sem</div>
            <div class="text-xs text-gray-500 mt-1">Implementación</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Por sector (verticales sectoriales) -->
    <section id="sectores" class="py-20 bg-white">
      <div class="max-w-[1200px] mx-auto px-6">
        <SectionHeader
          label={`${sectores.length} sectores · hubs verticales`}
          title="¿De qué rubro es su empresa? Empiece por aquí"
          description="Cada hub sectorial agrupa los agentes y la operación que sirve a un rubro específico, con el vocabulario y los casos reales del sector. Si no sabe qué agente necesita, entre por su rubro."
          centered
        />
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {sectores.map((s) => (
            <a
              href={s.url}
              class="group rounded-2xl bg-white border border-gray-200 p-6 hover:border-emerald-300 hover:shadow-lg transition-all flex flex-col"
            >
              <div class="text-4xl mb-3">{s.emoji}</div>
              <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-emerald-700 transition-colors leading-tight">
                {s.name}
              </h3>
              <p class="text-sm text-gray-500 mb-4 leading-relaxed line-clamp-3 flex-1">{s.shortDescription}</p>
              <div class="mt-auto pt-3 border-t border-gray-100">
                <div class="text-[11px] text-gray-400 uppercase tracking-wider mb-1.5">Aplica a</div>
                <div class="flex flex-wrap gap-1">
                  {s.targetIndustries.slice(0, 3).map((ind) => (
                    <span class="text-[11px] bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">{ind}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Verticales (por función) -->
    <section id="verticales" class="py-20 bg-gray-50">
      <div class="max-w-[1200px] mx-auto px-6">
        <SectionHeader
          label={`${agentes.length} agentes · por función`}
          title="¿Sabe qué tarea quiere automatizar?"
          description="Si ya tiene claro qué necesita (agendamiento, atención WhatsApp, calificación de leads, retención, compliance), entre por la función directa."
          centered
        />

        <div class="grid md:grid-cols-2 gap-6">
          {agentes.map((a) => (
            <a
              href={a.url}
              class="group rounded-2xl bg-white border border-gray-200 p-7 hover:border-emerald-300 hover:shadow-lg transition-all flex flex-col"
            >
              <div class="flex items-start justify-between mb-4">
                <div class="text-4xl">{a.emoji}</div>
                <div class="inline-flex items-center gap-1.5 bg-emerald-100 text-emerald-800 px-2.5 py-1 rounded-full text-xs font-medium">
                  <Sparkle class="w-3 h-3" />
                  Disponible ya
                </div>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-emerald-700 transition-colors">
                {a.name}
              </h3>
              <p class="text-gray-600 mb-5 leading-relaxed">{a.shortDescription}</p>

              <div class="mb-5">
                <div class="text-xs text-gray-400 uppercase tracking-wider mb-2">Para</div>
                <div class="flex flex-wrap gap-1.5">
                  {a.targetIndustries.map((ind) => (
                    <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">{ind}</span>
                  ))}
                </div>
              </div>

              <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between">
                <div>
                  <div class="text-xs text-gray-500">Desde</div>
                  <div class="font-semibold text-emerald-700">{a.pricing.saas[0]?.price || a.pricing.ventaUnica[0]?.price}</div>
                </div>
                <div class="text-emerald-700 font-medium text-sm inline-flex items-center gap-1.5 group-hover:gap-2.5 transition-all">
                  Ver landing
                  <ArrowRight class="w-4 h-4" />
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Why WhatsApp -->
    <section class="py-20 bg-white">
      <div class="max-w-[1100px] mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <Badge class="mb-4">El canal correcto en Chile</Badge>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-5">
              ¿Por qué WhatsApp y no email, web chat o app?
            </h2>
            <p class="text-gray-600 text-lg leading-relaxed mb-6">
              Porque ya está instalado en el 95% de los teléfonos en Chile y porque la apertura es 4.5x mayor que email. Cualquier otro canal parte en desventaja estructural.
            </p>
            <ul class="space-y-3">
              <li class="flex gap-3 text-gray-700">
                <Check class="w-5 h-5 text-emerald-600 shrink-0 mt-0.5" />
                <span><strong class="text-gray-900">98% apertura</strong> vs 21% del email</span>
              </li>
              <li class="flex gap-3 text-gray-700">
                <Check class="w-5 h-5 text-emerald-600 shrink-0 mt-0.5" />
                <span><strong class="text-gray-900">&gt;95% penetración</strong> en smartphones chilenos</span>
              </li>
              <li class="flex gap-3 text-gray-700">
                <Check class="w-5 h-5 text-emerald-600 shrink-0 mt-0.5" />
                <span><strong class="text-gray-900">Friction cero</strong> — sin descargar nada, sin crear cuenta</span>
              </li>
              <li class="flex gap-3 text-gray-700">
                <Check class="w-5 h-5 text-emerald-600 shrink-0 mt-0.5" />
                <span><strong class="text-gray-900">API oficial de Meta</strong> — sin riesgo de bloqueo, cumplimiento Ley 21.719</span>
              </li>
            </ul>
          </div>
          <div class="bg-emerald-800 rounded-2xl p-8 md:p-10 text-white">
            <p class="text-emerald-200 text-sm font-medium uppercase tracking-wider mb-2">Comercio conversacional LATAM</p>
            <div class="text-5xl md:text-6xl font-bold mb-2">+85%</div>
            <p class="text-emerald-100 mb-8">crecimiento en 2025. Chile lidera adopción de payment links por WhatsApp en la región (38%).</p>
            <div class="grid grid-cols-2 gap-4 border-t border-emerald-700 pt-6">
              <div>
                <div class="text-2xl font-bold">200-500</div>
                <div class="text-xs text-emerald-200 mt-1">conversaciones/día por agente (caso Chile)</div>
              </div>
              <div>
                <div class="text-2xl font-bold">&gt;95%</div>
                <div class="text-xs text-emerald-200 mt-1">tasa de éxito en resolución autónoma</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Roadmap (próximamente) -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-[1200px] mx-auto px-6">
        <SectionHeader
          label="Roadmap 2026"
          title="Próximos agentes en construcción"
          description="Si su vertical no está en v1 y tiene un caso urgente, hablemos: priorizamos el desarrollo de verticales con cliente piloto interesado."
          centered
        />

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {agentRoadmap.map((r) => (
            <div class="rounded-xl border border-gray-200 bg-white p-5 hover:border-emerald-200 transition-colors">
              <div class="flex items-center gap-3 mb-2">
                <div class="text-2xl">{r.emoji}</div>
                <h3 class="font-semibold text-gray-900">{r.name}</h3>
              </div>
              <p class="text-sm text-gray-500 leading-relaxed">{r.description}</p>
            </div>
          ))}
        </div>

        <div class="text-center mt-10">
          <Button
            href="https://wa.me/56945262335?text=Hola%2C%20me%20interesa%20un%20agente%20IA%20que%20no%20est%C3%A1%20en%20el%20cat%C3%A1logo"
            target="_blank"
            variant="outline"
            size="lg"
          >
            Proponer vertical
            <ArrowRight class="w-5 h-5" />
          </Button>
        </div>
      </div>
    </section>

    <!-- Financiamiento general -->
    <section class="py-20 bg-emerald-50">
      <div class="max-w-[1100px] mx-auto px-6">
        <SectionHeader
          label="Financiamiento público 2026"
          title="Cubra entre 60% y 100% del costo con fondos públicos"
          description="Asesoramos sin costo. Cada agente está mapeado al fondo correcto según su tamaño de empresa y región."
          centered
        />

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="rounded-xl bg-white border border-emerald-100 p-6">
            <div class="text-xs text-emerald-700 font-semibold mb-2">~100% cubierto</div>
            <div class="font-bold text-gray-900 mb-1">Kit Digital</div>
            <div class="text-sm text-gray-500 mb-3">SERCOTEC</div>
            <div class="text-lg font-bold text-emerald-700">$1.200.000</div>
            <div class="text-xs text-gray-400 mt-2">Microempresas · ideal Agendamiento Starter</div>
          </div>
          <div class="rounded-xl bg-emerald-700 text-white p-6">
            <div class="text-xs text-emerald-200 font-semibold mb-2">95% cubierto</div>
            <div class="font-bold mb-1">CRECE</div>
            <div class="text-sm text-emerald-200 mb-3">SERCOTEC</div>
            <div class="text-lg font-bold">$5.000.000</div>
            <div class="text-xs text-emerald-200 mt-2">Micro/Pequeña · WhatsApp atención Pro</div>
          </div>
          <div class="rounded-xl bg-white border border-emerald-100 p-6">
            <div class="text-xs text-emerald-700 font-semibold mb-2">60% cubierto</div>
            <div class="font-bold text-gray-900 mb-1">Digitalización Pyme</div>
            <div class="text-sm text-gray-500 mb-3">CORFO</div>
            <div class="text-lg font-bold text-emerald-700">$15M - $20M</div>
            <div class="text-xs text-gray-400 mt-2">Pymes · SDR / Retención / Custom</div>
          </div>
          <div class="rounded-xl bg-white border border-emerald-100 p-6">
            <div class="text-xs text-emerald-700 font-semibold mb-2">80% cubierto</div>
            <div class="font-bold text-gray-900 mb-1">Crea y Valida</div>
            <div class="text-sm text-gray-500 mb-3">CORFO (GYS Activa postula)</div>
            <div class="text-lg font-bold text-emerald-700">$180M</div>
            <div class="text-xs text-gray-400 mt-2">Validación de agente en N empresas</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Recursos por agente (artículos del blog) -->
    <section class="py-20 bg-white">
      <div class="max-w-[1200px] mx-auto px-6">
        <SectionHeader
          label="Recursos · Blog por vertical"
          title="Guías sectoriales y casos de uso"
          description="Cada agente tiene su propia biblioteca de artículos: cómo aplica al sector, ROI esperado, integraciones y financiamiento. Léalos antes de cotizar."
          centered
        />

        <div class="space-y-10">
          {agentes.map((a) => {
            const posts = (a.relatedBlogSlugs || [])
              .map((slug) => postsBySlug.get(slug))
              .filter(Boolean);
            if (posts.length === 0) return null;
            return (
              <div class="border border-gray-100 rounded-2xl p-6 md:p-8 bg-gray-50">
                <div class="flex items-center justify-between gap-4 mb-6 flex-wrap">
                  <div class="flex items-center gap-3">
                    <div class="text-3xl">{a.emoji}</div>
                    <div>
                      <h3 class="text-xl font-bold text-gray-900">{a.name}</h3>
                      <p class="text-sm text-gray-500">{a.shortDescription}</p>
                    </div>
                  </div>
                  <a
                    href={a.url}
                    class="inline-flex items-center gap-1.5 text-sm font-medium text-emerald-700 hover:text-emerald-800 transition-colors shrink-0"
                  >
                    Ver landing
                    <ArrowRight class="w-4 h-4" />
                  </a>
                </div>
                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
                  {posts.slice(0, 3).map((post) => (
                    <a
                      href={`/blog/${post.id}/`}
                      class="group flex flex-col bg-white rounded-xl border border-gray-200 p-5 hover:border-emerald-300 hover:shadow-sm transition-all"
                    >
                      <div class="flex items-center gap-2 mb-3 text-xs text-gray-500">
                        <span class="inline-flex items-center bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full font-medium">
                          Artículo
                        </span>
                        {post.data.readingTime && <span>· {post.data.readingTime}</span>}
                      </div>
                      <h4 class="font-semibold text-gray-900 text-[15px] mb-2 leading-snug line-clamp-3 group-hover:text-emerald-700 transition-colors">
                        {post.data.title}
                      </h4>
                      <p class="text-xs text-gray-500 leading-relaxed line-clamp-2 mb-3 flex-1">
                        {post.data.description}
                      </p>
                      <span class="text-emerald-700 font-medium text-xs inline-flex items-center gap-1.5 group-hover:gap-2.5 transition-all">
                        Leer
                        <ArrowRight class="w-3.5 h-3.5" />
                      </span>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>

        <div class="text-center mt-12">
          <Button href="/blog/" variant="outline" size="lg">
            Ver todos los artículos del blog
            <ArrowRight class="w-5 h-5" />
          </Button>
        </div>
      </div>
    </section>

    <!-- Madurez IA Callout -->
    <MadurezIACallout slug="hub" />
  </main>

  <ContactCTA />
  <ContactForm />
  <Footer />
</Layout>
