---
import '../styles/global.css';
import { siteConfig } from '../data/content';
import WhatsAppButton from '../components/WhatsAppButton.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  keywords?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  canonical = siteConfig.canonical,
  keywords = siteConfig.keywords,
  ogTitle = siteConfig.ogTitle,
  ogDescription = siteConfig.ogDescription,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-T6C62NRP');</script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CL" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={ogTitle}>
    <meta name="twitter:description" content={ogDescription}>

    <!-- Open Graph -->
    <meta property="og:url" content="https://appsdelsur.cl/">
    <meta property="og:site_name" content="Apps del Sur">

    <!-- Robots -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">

    <!-- Google Search Console -->
    <meta name="google-site-verification" content="meBKJSxEefxYVx35H0xV4yT0rR9ZOjcBbC101xJZuh8" />

    <!-- Geo tags para SEO local -->
    <meta name="geo.region" content="CL-ML">
    <meta name="geo.placename" content="Maule, Chile">
    <meta name="geo.position" content="-35.4264;-71.6554">
    <meta name="ICBM" content="-35.4264, -71.6554">

    <!-- Idioma alternativo -->
    <link rel="alternate" hreflang="es-CL" href="https://appsdelsur.cl/">
    <link rel="alternate" hreflang="es" href="https://appsdelsur.cl/">

    <!-- Schema JSON-LD: Organization + SoftwareApplication -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://appsdelsur.cl/#organization",
          "name": "GYS Activa SpA",
          "brand": {
            "@type": "Brand",
            "name": "Apps del Sur"
          },
          "url": "https://appsdelsur.cl",
          "logo": "https://appsdelsur.cl/logo.png",
          "description": "Empresa chilena de desarrollo de software a medida para empresas del centro-sur de Chile. Soluciones para agro, servicios y consultoría IA con Claude. Atendemos O'Higgins, Maule, Ñuble, Biobío y Araucanía.",
          "foundingDate": "2025",
          "founder": {
            "@type": "Person",
            "name": "Darío Ramírez"
          },
          "address": {
            "@type": "PostalAddress",
            "addressRegion": "Maule",
            "addressCountry": "CL"
          },
          "areaServed": [
            {"@type": "AdministrativeArea", "name": "Región de O'Higgins"},
            {"@type": "AdministrativeArea", "name": "Región del Maule"},
            {"@type": "AdministrativeArea", "name": "Región de Ñuble"},
            {"@type": "AdministrativeArea", "name": "Región del Biobío"},
            {"@type": "AdministrativeArea", "name": "Región de La Araucanía"}
          ],
          "contactPoint": {
            "@type": "ContactPoint",
            "telephone": "+56-9-4526-2335",
            "contactType": "sales",
            "availableLanguage": "Spanish",
            "email": "contacto@appsdelsur.cl"
          },
          "sameAs": []
        },
        {
          "@type": "SoftwareApplication",
          "@id": "https://appsdelsur.cl/#software",
          "name": "Apps del Sur",
          "applicationCategory": "BusinessApplication",
          "operatingSystem": "Web, Android, iOS",
          "description": "Software a medida para empresas del centro-sur de Chile. Plataforma web de gestión + app móvil que funciona offline. Desarrollo asistido por Claude AI. Soluciones para agro, servicios y consultoría IA.",
          "url": "https://appsdelsur.cl",
          "provider": {"@id": "https://appsdelsur.cl/#organization"},
          "offers": [
            {
              "@type": "Offer",
              "name": "Diagnóstico gratuito",
              "price": "0",
              "priceCurrency": "CLP",
              "description": "Análisis de su operación actual y propuesta personalizada sin compromiso"
            },
            {
              "@type": "Offer",
              "name": "Compra de licencia + implementación",
              "priceRange": "$8.000.000 - $12.000.000 CLP",
              "priceCurrency": "CLP",
              "description": "Proyecto de 8-12 semanas. Sistema a medida: plataforma web + app móvil + capacitación presencial + soporte 12 meses. Financiamiento CORFO/FIA disponible (50-98%)."
            },
            {
              "@type": "Offer",
              "name": "Suscripción mensual",
              "price": "450000",
              "priceCurrency": "CLP",
              "description": "Setup $2.5M CLP + $450K CLP/mes. Incluye actualizaciones y soporte continuo."
            }
          ],
          "featureList": [
            "Costos en tiempo real por área, proyecto y actividad",
            "App móvil de registro que funciona offline",
            "Trazabilidad 100% por trabajador, área y actividad",
            "70% reducción en tiempo administrativo",
            "Reportes automáticos para gerencia y administración",
            "Cumplimiento normativo laboral chilena",
            "Desarrollo asistido por Claude AI",
            "Capacitación presencial en terreno",
            "Consultoría para integración de IA en procesos de negocio"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "https://appsdelsur.cl/#website",
          "url": "https://appsdelsur.cl",
          "name": "Apps del Sur",
          "description": "Software a medida para empresas del centro-sur de Chile. Agro, servicios y consultoría IA con Claude.",
          "publisher": {"@id": "https://appsdelsur.cl/#organization"},
          "inLanguage": "es-CL"
        },
        {
          "@type": "WebPage",
          "@id": "https://appsdelsur.cl/#webpage",
          "url": "https://appsdelsur.cl",
          "name": "Apps del Sur — Software a Medida para Empresas del Sur de Chile | Maule",
          "description": "Apps del Sur desarrolla software a medida para empresas del centro-sur de Chile. Gestión agrícola, servicios y consultoría IA con Claude. Financiamiento CORFO/FIA disponible.",
          "isPartOf": {"@id": "https://appsdelsur.cl/#website"},
          "about": {"@id": "https://appsdelsur.cl/#software"},
          "inLanguage": "es-CL"
        }
      ]
    }
    </script>

    <!-- Schema JSON-LD: FAQ -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué hace diferente a Apps del Sur de un sistema genérico?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No ofrecemos un software genérico donde usted se adapta al sistema. Desarrollamos una plataforma a medida que se configura con sus procesos, equipos, áreas y estructura de costos reales. Gracias al desarrollo asistido por Claude AI, podemos ofrecer esta personalización a precios accesibles."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué es Claude AI y cómo lo usan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Claude AI es un modelo de inteligencia artificial desarrollado por Anthropic. Lo usamos como herramienta de desarrollo para acelerar cada etapa del proyecto: desde el análisis de su operación hasta la generación de código. Esto nos permite entregar software custom en 8-12 semanas en vez de 6+ meses, a una fracción del costo tradicional."
          }
        },
        {
          "@type": "Question",
          "name": "¿Funciona sin conexión a internet?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Nuestras aplicaciones móviles están diseñadas para funcionar offline. Los datos se sincronizan automáticamente cuando el dispositivo recupera la conexión, ideal para zonas rurales del centro-sur de Chile."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo toma implementar el sistema en mi operación?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El proyecto de implementación toma entre 8 y 12 semanas, incluyendo el desarrollo a medida de la plataforma web y app móvil, configuración de procesos y estructura de costos, y capacitación del equipo."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta y qué modalidades ofrecen?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ofrecemos dos modalidades: (1) Compra de licencia con implementación completa por $8-12M CLP, que incluye plataforma web, app móvil, capacitación presencial y 12 meses de soporte. (2) Suscripción mensual de $450K CLP/mes con setup inicial de $2.5M CLP. Ambas modalidades son financiables con fondos públicos CORFO, FIA y SERCOTEC (50-80% del proyecto)."
          }
        },
        {
          "@type": "Question",
          "name": "¿Existen fondos públicos para financiar la implementación?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Instrumentos como CORFO Crea y Valida, FIA Innovación y SERCOTEC CRECE pueden financiar entre el 50% y el 80% del proyecto. En algunos casos, el cliente piloto puede acceder al sistema a costo $0. Asesoramos en la postulación."
          }
        }
      ]
    }
    </script>

    <!-- Schema JSON-LD: LocalBusiness -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://appsdelsur.cl/#localbusiness",
      "name": "Apps del Sur — GYS Activa SpA",
      "description": "Desarrollo de software a medida para empresas del centro-sur de Chile. Soluciones para agro, servicios y consultoría IA con Claude AI.",
      "url": "https://appsdelsur.cl",
      "telephone": "+56-9-4526-2335",
      "email": "contacto@appsdelsur.cl",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "Maule",
        "addressCountry": "CL"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -35.4264,
        "longitude": -71.6554
      },
      "areaServed": ["O'Higgins", "Maule", "Ñuble", "Biobío", "Araucanía"],
      "priceRange": "$$$",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:00",
        "closes": "18:00"
      }
    }
    </script>
  </head>
  <body class="min-h-screen bg-white font-sans">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T6C62NRP"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <slot />
    <WhatsAppButton />
  </body>
</html>
