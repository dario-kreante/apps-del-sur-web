---
import Layout from './Layout.astro';

// Hero illustrations — imported statically for Astro SSG
import HeroCuadernoCampo from '../components/blog-heroes/HeroCuadernoCampo.astro';
import HeroCalendarioAgricola from '../components/blog-heroes/HeroCalendarioAgricola.astro';
import HeroSenalesDigitalizar from '../components/blog-heroes/HeroSenalesDigitalizar.astro';
import HeroSustentavid from '../components/blog-heroes/HeroSustentavid.astro';
import HeroVendimia from '../components/blog-heroes/HeroVendimia.astro';
import HeroEcosistemaAgtech from '../components/blog-heroes/HeroEcosistemaAgtech.astro';
import HeroFinanciamiento from '../components/blog-heroes/HeroFinanciamiento.astro';
import HeroCostoManoObra from '../components/blog-heroes/HeroCostoManoObra.astro';
import HeroComparativaSoftware from '../components/blog-heroes/HeroComparativaSoftware.astro';

const heroComponents: Record<string, any> = {
  'cuaderno-de-campo-digital-vinas-chile': HeroCuadernoCampo,
  'calendario-agricola-2026-vinas-centro-sur-chile': HeroCalendarioAgricola,
  'senales-digitalizar-gestion-mano-obra-vina': HeroSenalesDigitalizar,
  'sustentavid-globalg-a-p-registros-trazabilidad-software': HeroSustentavid,
  'vendimia-2026-gestion-temporeros-costos': HeroVendimia,
  'ecosistema-agtech-maule-thinkagro-inia-recursos': HeroEcosistemaAgtech,
  'guia-financiamiento-corfo-fia-digitalizacion-agricola-2026': HeroFinanciamiento,
  'costo-mano-de-obra-por-hectarea-vinas-chile': HeroCostoManoObra,
  'software-agricola-chile-comparativa-2026': HeroComparativaSoftware,
};

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  readingTime: string;
  heroAlt: string;
  tags: string[];
  relatedPosts?: string[];
  slug: string;
}

const { title, description, pubDate, updatedDate, author, readingTime, heroAlt, tags, relatedPosts, slug } = Astro.props;

const HeroComponent = heroComponents[slug];

const formattedDate = pubDate.toLocaleDateString('es-CL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('es-CL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalUrl = `https://appsdelsur.cl/blog/${slug}`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: 'https://appsdelsur.cl/og-image-blog.png',
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: author,
    affiliation: {
      '@type': 'Organization',
      name: 'GYS Activa SpA',
    },
  },
  publisher: {
    '@type': 'Organization',
    name: 'Apps del Sur',
    logo: {
      '@type': 'ImageObject',
      url: 'https://appsdelsur.cl/logo.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
});
---

<Layout title={`${title} | Apps del Sur`} description={description}>
  <script type="application/ld+json" set:html={jsonLd} />

  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
    <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <span class="font-semibold text-gray-900 text-[15px]">Apps del Sur</span>
      </a>
      <nav class="flex items-center gap-4">
        <a href="/blog" class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Blog</a>
        <a href="/#contacto" class="text-sm font-medium text-white bg-emerald-600 hover:bg-emerald-700 px-4 py-2 rounded-lg transition-colors">Contacto</a>
      </nav>
    </div>
  </header>

  <main id="main-content" class="pt-24 pb-16">
    <!-- Breadcrumb -->
    <div class="max-w-3xl mx-auto px-6 mb-6">
      <nav class="text-sm text-gray-500" aria-label="Breadcrumb">
        <a href="/" class="text-emerald-600 hover:text-emerald-700 transition-colors">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/blog" class="text-emerald-600 hover:text-emerald-700 transition-colors">Blog</a>
        <span class="mx-2">/</span>
        <span class="text-gray-400">{title.length > 50 ? title.slice(0, 50) + '...' : title}</span>
      </nav>
    </div>

    <!-- Hero Illustration -->
    {HeroComponent && (
      <div class="max-w-3xl mx-auto px-6 mb-8">
        <div class="rounded-2xl overflow-hidden" role="img" aria-label={heroAlt}>
          <HeroComponent class="w-full h-auto" />
        </div>
      </div>
    )}

    <!-- Article -->
    <article class="max-w-3xl mx-auto px-6">
      <!-- Article Header -->
      <header class="mb-10 pb-8 border-b border-gray-200">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">{title}</h1>

        <p class="text-lg text-gray-600 mb-6">{description}</p>

        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          </span>
          {formattedUpdatedDate && (
            <span class="text-gray-400">(actualizado {formattedUpdatedDate})</span>
          )}
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            {readingTime}
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            {author}
          </span>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="inline-block bg-emerald-50 text-emerald-700 text-xs font-medium px-2.5 py-1 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <!-- Article Content -->
      <div class="prose prose-lg prose-gray max-w-none
        prose-headings:text-gray-900 prose-headings:font-bold
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:pt-6 prose-h2:border-t-2 prose-h2:border-gray-100
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-h4:text-lg prose-h4:mt-6 prose-h4:mb-2
        prose-p:text-gray-700 prose-p:leading-relaxed
        prose-a:text-emerald-600 prose-a:font-medium prose-a:no-underline hover:prose-a:underline
        prose-strong:text-gray-900
        prose-blockquote:border-l-4 prose-blockquote:border-emerald-500 prose-blockquote:bg-emerald-50 prose-blockquote:rounded-r-lg prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:not-italic prose-blockquote:text-gray-700
        prose-table:text-sm
        prose-th:bg-gray-800 prose-th:text-white prose-th:font-semibold prose-th:px-4 prose-th:py-3
        prose-td:px-4 prose-td:py-3 prose-td:border-b prose-td:border-gray-200
        prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:text-gray-800
        prose-ul:text-gray-700 prose-ol:text-gray-700
        prose-li:text-gray-700
      ">
        <slot />
      </div>

      <!-- Related Posts -->
      {relatedPosts && relatedPosts.length > 0 && (
        <div class="mt-16 pt-8 border-t border-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-4">Artículos relacionados</h3>
          <div class="space-y-3">
            {relatedPosts.map((postSlug) => (
              <a
                href={`/blog/${postSlug}`}
                class="block p-4 bg-gray-50 hover:bg-emerald-50 rounded-lg border-l-3 border-emerald-500 transition-colors"
              >
                <span class="text-emerald-600 font-medium">{postSlug.replace(/-/g, ' ')}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- CTA Banner -->
      <div class="mt-16 bg-gradient-to-br from-emerald-600 to-emerald-800 rounded-2xl p-8 md:p-10 text-center text-white">
        <h3 class="text-2xl font-bold mb-3">Solicita tu diagnóstico gratuito</h3>
        <p class="text-emerald-100 mb-6 max-w-lg mx-auto">
          Si tu viña o empresa agrícola está en el centro-sur de Chile, podemos ayudarte a evaluar opciones de digitalización y financiamiento. Sin costo, sin compromiso.
        </p>
        <a
          href="/#contacto"
          class="inline-block bg-white text-emerald-700 font-semibold px-8 py-3 rounded-lg hover:bg-emerald-50 transition-colors"
        >
          Solicitar diagnóstico
        </a>
      </div>
    </article>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-400 py-10">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-sm">
        <strong class="text-white">Apps del Sur</strong> — Software de gestión de mano de obra agrícola para viñas del centro-sur de Chile.
      </p>
      <div class="flex justify-center gap-6 mt-4 text-sm">
        <a href="/" class="text-emerald-400 hover:text-emerald-300 transition-colors">Inicio</a>
        <a href="/blog" class="text-emerald-400 hover:text-emerald-300 transition-colors">Blog</a>
        <a href="/#contacto" class="text-emerald-400 hover:text-emerald-300 transition-colors">Contacto</a>
      </div>
      <p class="mt-4 text-xs text-gray-500">&copy; 2026 GYS Activa SpA. Todos los derechos reservados.</p>
    </div>
  </footer>
</Layout>
